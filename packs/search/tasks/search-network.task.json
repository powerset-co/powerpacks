{
  "task": "search_network",
  "version": 1,
  "description": "Plan and execute a role-first people search with explicit state, primitive outputs, and frontier assessment.",
  "default_constraints": {
    "no_llm_enrichment": true,
    "no_summary_search": true,
    "no_company_signal_search": true,
    "no_expensive_scoring": true
  },
  "steps": [
    {
      "id": "expand_search_request",
      "kind": "reasoning",
      "primitive": "expand_search_request",
      "skill": "extract-search-query",
      "output_schema": "decomposed-query.schema.json"
    },
    {
      "id": "plan_adjacency_search",
      "kind": "reasoning",
      "primitive": "plan_adjacency_search",
      "output_schema": "adjacency-plan.schema.json",
      "optional": true
    },
    {
      "id": "decide_search_strategy",
      "kind": "reasoning",
      "primitive": "decide_search_strategy",
      "output_schema": "search-strategy-decision.schema.json"
    },
    {
      "id": "resolve_set_operators",
      "kind": "primitive",
      "primitive": "resolve_set_operators",
      "optional": true,
      "note": "Run before company, prefilter, count, or role retrieval so set_id/default-set scoping becomes TurboPuffer operator_ids."
    },
    {
      "id": "resolve_education",
      "kind": "primitive",
      "primitive": "resolve_education",
      "optional": true
    },
    {
      "id": "resolve_companies",
      "kind": "primitive",
      "primitive": "resolve_companies",
      "optional": true
    },
    {
      "id": "resolve_investors",
      "kind": "primitive",
      "primitive": "resolve_investors",
      "optional": true,
      "note": "Run before resolve_companies when investor names must become investor URNs for company filtering."
    },
    {
      "id": "apply_prefilters",
      "kind": "primitive",
      "primitive": "apply_prefilters",
      "optional": true,
      "note": "Run before count/search when education, tech skills, social/interaction, or large company intersections must produce base IDs."
    },
    {
      "id": "count_candidates",
      "kind": "primitive",
      "primitive": "count_candidates",
      "optional": true
    },
    {
      "id": "generate_search_slices",
      "kind": "reasoning",
      "primitive": "generate_search_slices",
      "output_schema": "search-slice.schema.json",
      "optional": true
    },
    {
      "id": "execute_search_slice",
      "kind": "primitive",
      "primitive": "execute_search_slice",
      "optional": true
    },
    {
      "id": "execute_role_search",
      "kind": "primitive",
      "primitive": "execute_role_search",
      "optional": true
    },
    {
      "id": "merge_candidate_frontier",
      "kind": "primitive",
      "primitive": "merge_candidate_frontier",
      "optional": true
    },
    {
      "id": "assess_frontier",
      "kind": "reasoning",
      "primitive": "assess_frontier",
      "output_schema": "frontier-assessment.schema.json"
    },
    {
      "id": "plan_candidate_review",
      "kind": "reasoning",
      "primitive": "plan_candidate_review",
      "output_schema": "candidate-review-plan.schema.json"
    },
    {
      "id": "hydrate_people",
      "kind": "primitive",
      "primitive": "hydrate_people",
      "note": "Hydrate the full candidate frontier before LLM filtering."
    },
    {
      "id": "llm_filter_candidates",
      "kind": "primitive",
      "primitive": "llm_filter_candidates",
      "output_schema": "llm-filter-candidates.schema.json",
      "optional": true
    },
    {
      "id": "persist_search_results",
      "kind": "primitive",
      "primitive": "persist_search_results"
    }
  ]
}
