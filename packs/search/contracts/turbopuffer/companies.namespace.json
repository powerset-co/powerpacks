{
  "name": "companies",
  "type": "turbopuffer_namespace",
  "version": "2026-04-29",
  "namespace": "aleph_companies_v1",
  "document_grain": "company",
  "description": "Company semantic search namespace for resolving company sets, sectors, funding/headcount bands, and adjacency seed companies.",
  "vector": {"dimension": 1536, "distance_metric": "cosine_distance"},
  "attributes": [
    {"name": "id", "type": "string", "notes": "Company URN."},
    {"name": "company_urn", "type": "string", "notes": "Alias for id retained for Aleph artifact compatibility."},
    {"name": "company_name", "type": "string"},
    {"name": "aliases", "type": "string"},
    {"name": "name_aliases_text", "type": "string"},
    {"name": "semantic_text", "type": "string"},
    {"name": "entity_sector_text", "type": "string"},
    {"name": "word_text", "type": "string"},
    {"name": "doc2query", "type": "string[]"},
    {"name": "doc2query_text", "type": "string"},
    {"name": "website_domain", "type": "string"},
    {"name": "linkedin_url", "type": "string"},
    {"name": "description", "type": "string"},
    {"name": "headcount", "type": "number"},
    {"name": "funding_total", "type": "number"},
    {"name": "funding_stage", "type": "integer"},
    {"name": "stage", "type": "string"},
    {"name": "city", "type": "string"},
    {"name": "state", "type": "string"},
    {"name": "country", "type": "string"},
    {"name": "metro_area", "type": "string"},
    {"name": "macro_region", "type": "string"},
    {"name": "entity_types", "type": "string[]"},
    {"name": "sector_types", "type": "string[]"},
    {"name": "technology_types", "type": "string[]"},
    {"name": "customer_type", "type": "string[]"},
    {"name": "investor_urns", "type": "string[]"},
    {"name": "accelerators", "type": "string[]"},
    {"name": "yc_batches", "type": "string[]"},
    {"name": "founded_year", "type": "integer"},
    {"name": "last_funding_at", "type": "integer"},
    {"name": "valuation", "type": "number"},
    {"name": "logo_url", "type": "string"},
    {"name": "allowed_operator_ids", "type": "string[]"}
  ],
  "filters": [
    {"field": "company_name", "operators": ["Eq", "In"], "value_type": "string/string[]"},
    {"field": "company_urn", "operators": ["Eq", "In"], "value_type": "string/string[]"},
    {"field": "city", "operators": ["In"], "value_type": "string[]"},
    {"field": "state", "operators": ["In"], "value_type": "string[]"},
    {"field": "country", "operators": ["In"], "value_type": "string[]"},
    {"field": "metro_area", "operators": ["In"], "value_type": "string[]"},
    {"field": "macro_region", "operators": ["In"], "value_type": "string[]"},
    {"field": "funding_stage", "operators": ["Eq", "Gte", "Lte", "In"], "value_type": "integer/integer[]"},
    {"field": "funding_total", "operators": ["Gte", "Lte"], "value_type": "number"},
    {"field": "headcount", "operators": ["Gte", "Lte"], "value_type": "number"},
    {"field": "entity_types", "operators": ["ContainsAny"], "value_type": "string[]"},
    {"field": "sector_types", "operators": ["ContainsAny"], "value_type": "string[]"},
    {"field": "technology_types", "operators": ["ContainsAny"], "value_type": "string[]"},
    {"field": "customer_type", "operators": ["ContainsAny"], "value_type": "string[]"},
    {"field": "investor_urns", "operators": ["ContainsAny"], "value_type": "string[]"},
    {"field": "accelerators", "operators": ["ContainsAny"], "value_type": "string[]"},
    {"field": "yc_batches", "operators": ["ContainsAny"], "value_type": "string[]"},
    {"field": "stage", "operators": ["Eq", "In"], "value_type": "string/string[]"},
    {"field": "founded_year", "operators": ["Gte", "Lte"], "value_type": "integer"},
    {"field": "last_funding_at", "operators": ["Gte", "Lte"], "value_type": "integer"},
    {"field": "valuation", "operators": ["Gte", "Lte"], "value_type": "number"},
    {"field": "allowed_operator_ids", "operators": ["ContainsAny"], "value_type": "string[]"}
  ],
  "rules": [
    "Use for company resolution or adjacency planning, then pass resolved company ids into people searches.",
    "Do not use company signals or summary generation in V1."
  ]
}
