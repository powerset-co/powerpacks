{
  "name": "people",
  "type": "turbopuffer_namespace",
  "version": "2026-04-29",
  "namespace": "aleph_people_v1",
  "document_grain": "person_position",
  "id_semantics": "Document ids may be base person UUIDs or base person UUID plus a position suffix. Use base_id as the person id when present.",
  "vector": {"dimension": 1536, "distance_metric": "cosine_distance"},
  "text_query_fields": [
    "position_title",
    "word_tokens",
    "char_tokens",
    "d2q_tokens",
    "phrase_tokens"
  ],
  "attributes": [
    {"name": "id", "type": "string", "notes": "Position/document id."},
    {"name": "base_id", "type": "string", "notes": "Base person id used for hydration."},
    {"name": "person_id", "type": "string", "notes": "Alias for base_id used by local DuckDB/profile joins."},
    {"name": "position_id", "type": "string", "notes": "Stable position id; usually same as id for local records."},
    {"name": "title_hash", "type": "string", "notes": "Upstream role enrichment/embedding key."},
    {"name": "raw_title", "type": "string", "notes": "Original title used for role enrichment."},
    {"name": "role_type_category", "type": "string", "notes": "LLM role_type copied from role enrichment for debugging/filtering."},
    {"name": "position_title", "type": "string"},
    {"name": "description", "type": "string", "notes": "Role description for local hydration/profile XML."},
    {"name": "dense_text", "type": "string", "notes": "Compact title/company/description text for local hydration/profile XML."},
    {"name": "word_tokens", "type": "string[]"},
    {"name": "char_tokens", "type": "string[]"},
    {"name": "d2q_tokens", "type": "string[]"},
    {"name": "phrase_tokens", "type": "string[]"},
    {"name": "city", "type": "string"},
    {"name": "state", "type": "string"},
    {"name": "country", "type": "string"},
    {"name": "macro_region", "type": "string"},
    {"name": "metro_areas", "type": "string[]"},
    {"name": "seniority_band", "type": "string"},
    {"name": "company_id", "type": "string"},
    {"name": "company_domain", "type": "string"},
    {"name": "company_linkedin_url", "type": "string"},
    {"name": "company_description", "type": "string"},
    {"name": "company_sector_types", "type": "string[]"},
    {"name": "company_entity_types", "type": "string[]"},
    {"name": "company_headcount", "type": "integer"},
    {"name": "company_funding_total", "type": "number"},
    {"name": "company_stage", "type": "string"},
    {"name": "investor_names", "type": "string[]"},
    {"name": "is_current", "type": "boolean"},
    {"name": "total_years_experience", "type": "number"},
    {"name": "tenure_years", "type": "number"},
    {"name": "start_date_epoch", "type": "integer", "notes": "Use with Lte for overlap windows."},
    {"name": "end_date_epoch", "type": "integer", "notes": "Use with Gte or Eq/null-current semantics for overlap windows."},
    {"name": "role_track", "type": "string"},
    {"name": "allowed_operator_ids", "type": "string[]"},
    {"name": "role_ids", "type": "string[]"},
    {"name": "inferred_birth_year", "type": "integer"},
    {"name": "x_twitter_followers", "type": "integer"},
    {"name": "linkedin_followers", "type": "integer"},
    {"name": "linkedin_connections", "type": "integer"},
    {"name": "ig_followers", "type": "integer"}
  ],
  "filters": [
    {"field": "city", "operators": ["In"], "value_type": "string[]"},
    {"field": "state", "operators": ["In"], "value_type": "string[]"},
    {"field": "country", "operators": ["In"], "value_type": "string[]"},
    {"field": "macro_region", "operators": ["In"], "value_type": "string[]"},
    {"field": "metro_areas", "operators": ["ContainsAny"], "value_type": "string[]"},
    {"field": "seniority_band", "operators": ["In", "NotIn"], "value_type": "string[]"},
    {"field": "company_id", "operators": ["In"], "value_type": "string[]"},
    {"field": "is_current", "operators": ["Eq"], "value_type": "boolean"},
    {"field": "total_years_experience", "operators": ["Gte", "Lte"], "value_type": "number"},
    {"field": "start_date_epoch", "operators": ["Lte"], "value_type": "integer"},
    {"field": "end_date_epoch", "operators": ["Gte", "Eq"], "value_type": "integer/null"},
    {"field": "role_track", "operators": ["In"], "value_type": "string[]"},
    {"field": "allowed_operator_ids", "operators": ["ContainsAny"], "value_type": "string[]"},
    {"field": "role_ids", "operators": ["ContainsAny"], "value_type": "string[]"},
    {"field": "base_id", "operators": ["In"], "value_type": "string[]"},
    {"field": "person_id", "operators": ["In"], "value_type": "string[]"},
    {"field": "position_id", "operators": ["In"], "value_type": "string[]"},
    {"field": "title_hash", "operators": ["In"], "value_type": "string[]"},
    {"field": "inferred_birth_year", "operators": ["Gte", "Lte"], "value_type": "integer"},
    {"field": "x_twitter_followers", "operators": ["Gte", "Lte"], "value_type": "integer"},
    {"field": "linkedin_followers", "operators": ["Gte", "Lte"], "value_type": "integer"},
    {"field": "linkedin_connections", "operators": ["Gte", "Lte"], "value_type": "integer"},
    {"field": "ig_followers", "operators": ["Gte", "Lte"], "value_type": "integer"}
  ],
  "rules": [
    "Do not invent attributes or operators.",
    "For tenure at a company between dates, use overlapping position windows rather than only start_date filtering.",
    "For broad result sets, count first or slice by seniority, geography, title strictness, currentness, company strictness, adjacency mode, prefilter plan, and candidate limit."
  ]
}
