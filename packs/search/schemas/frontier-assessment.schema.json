{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://powerpacks/schemas/frontier-assessment.schema.json",
  "title": "FrontierAssessment",
  "type": "object",
  "additionalProperties": false,
  "required": ["frontier_size", "quality_signal", "recommended_next_action", "reasons"],
  "properties": {
    "frontier_size": { "type": "integer" },
    "quality_signal": {
      "type": "string",
      "enum": ["too_broad", "too_narrow", "coherent", "mixed", "unknown"]
    },
    "recommended_next_action": {
      "type": "string",
      "enum": ["hydrate_frontier", "narrow_filters", "widen_with_new_slice", "run_additional_direct_query", "ask_for_clarification", "stop_and_present"]
    },
    "suggested_hydration_count": { "type": "integer" },
    "best_slices": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
