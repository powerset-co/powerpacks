{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://powerpacks/schemas/task-run.schema.json",
  "title": "TaskRun",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "task", "status", "query", "created_at", "updated_at", "steps"],
  "properties": {
    "task_id": { "type": "string" },
    "task": {
      "type": "string",
      "enum": ["search_network"]
    },
    "status": {
      "type": "string",
      "enum": ["running", "awaiting_approval", "completed", "failed", "paused"]
    },
    "query": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "constraints": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "plan": {
      "type": "object"
    },
    "search_plan_revisions": {
      "type": "array",
      "description": "Append-only search-plan versions created from user feedback or agent refinement.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["recorded_at", "revision_id"],
        "properties": {
          "recorded_at": { "type": "string" },
          "revision_id": { "type": "string" },
          "revision": { "type": "integer" },
          "reason": { "type": "string" },
          "user_feedback": { "type": "string" },
          "criteria_delta": { "type": "object" },
          "plan": { "type": "object" }
        }
      }
    },
    "candidate_feedback": {
      "type": "array",
      "description": "Append-only candidate labels and feedback supplied by the user or reviewer.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["recorded_at", "feedback_id"],
        "properties": {
          "recorded_at": { "type": "string" },
          "feedback_id": { "type": "string" },
          "person_id": { "type": "string" },
          "label": { "type": "string" },
          "reason": { "type": "string" },
          "applied_to_next_search": { "type": "boolean" }
        }
      }
    },
    "criteria_mutations": {
      "type": "array",
      "description": "Append-only changes to hard filters, soft filters, reject criteria, budget, or fan-out strategy.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["recorded_at", "mutation_id"],
        "properties": {
          "recorded_at": { "type": "string" },
          "mutation_id": { "type": "string" },
          "source_feedback_ids": { "type": "array", "items": { "type": "string" } },
          "mutation": { "type": "object" },
          "reason": { "type": "string" }
        }
      }
    },
    "run_lineage": {
      "type": "array",
      "description": "Links between this run, parent runs, child fan-outs, and artifact/state paths.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["recorded_at", "lineage_id"],
        "properties": {
          "recorded_at": { "type": "string" },
          "lineage_id": { "type": "string" },
          "relationship": { "type": "string" },
          "task_id": { "type": "string" },
          "state": { "type": "string" },
          "artifact_dir": { "type": "string" }
        }
      }
    },
    "exemplar_sets": {
      "type": "array",
      "description": "Candidate exemplars selected for clustering/fan-out.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["recorded_at", "exemplar_set_id"],
        "properties": {
          "recorded_at": { "type": "string" },
          "exemplar_set_id": { "type": "string" },
          "name": { "type": "string" },
          "person_ids": { "type": "array", "items": { "type": "string" } },
          "selection_reason": { "type": "string" }
        }
      }
    },
    "fanout_threads": {
      "type": "array",
      "description": "Clustered fan-out threads, their criteria, budgets, state paths, and results.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["recorded_at", "thread_id"],
        "properties": {
          "recorded_at": { "type": "string" },
          "thread_id": { "type": "string" },
          "cluster_label": { "type": "string" },
          "criteria": { "type": "object" },
          "state": { "type": "string" },
          "artifact_dir": { "type": "string" }
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "recorded_at"],
        "properties": {
          "id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "completed", "failed", "skipped"]
          },
          "recorded_at": { "type": "string" },
          "elapsed_ms": { "type": "integer" },
          "output": {},
          "note": { "type": "string" }
        }
      }
    },
    "planned_steps": {
      "type": "array",
      "description": "Mutable checklist of the intended plan. The append-only steps array remains the execution log.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "completed", "failed", "skipped"]
          },
          "planned_at": { "type": "string" },
          "started_at": { "type": "string" },
          "completed_at": { "type": "string" },
          "updated_at": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "summary": {
      "type": "object"
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "changes_requested"]
        },
        "requested_at": { "type": "string" },
        "approved_at": { "type": "string" },
        "changed_at": { "type": "string" },
        "approved_by": { "type": "string" },
        "requested_by": { "type": "string" },
        "execution_mode": {
          "type": "string",
          "enum": ["search_only", "rerank"]
        },
        "reason": { "type": "string" },
        "proposed_next_step": { "type": "string" },
        "note": { "type": "string" },
        "plan": { "type": "object" }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "task_id": { "type": "string" },
        "query": { "type": "string" },
        "state": { "type": "string" },
        "created_at": { "type": "string" },
        "artifact_dir": { "type": "string" },
        "csv": { "type": "string" },
        "jsonl": { "type": "string" },
        "manifest": { "type": "string" },
        "row_count": { "type": "integer" },
        "hydrated_count": { "type": "integer" },
        "frontier_count": { "type": "integer" },
        "agentic_candidate_review": {
          "type": "object",
          "additionalProperties": true,
          "description": "Sharded review manifest, shard paths, expected output paths, and final ranked artifacts."
        }
      }
    }
  }
}
