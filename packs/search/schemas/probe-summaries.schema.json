{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://powerpacks.local/schemas/probe-summaries.schema.json",
  "title": "Search Network JD Probe Summaries",
  "description": "Canonical shape of probe_summaries.json: a bare JSON array of probe summary objects, one per executed profile search. Generated by merge_candidate_frontier.py collect-probes; never hand-authored. Legacy agent-authored files wrapped the list in {\"probes\": [...]} or {\"probe_summaries\": [...]}; consumers tolerate that via packs/search/primitives/shared/probe_artifacts.py, but the wrapper is not part of this schema.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "status",
      "query"
    ],
    "properties": {
      "id": {
        "type": "string",
        "minLength": 1
      },
      "status": {
        "type": "string",
        "enum": [
          "completed",
          "failed"
        ]
      },
      "query": {
        "type": "string",
        "minLength": 1
      },
      "artifact_dir": {
        "type": [
          "string",
          "null"
        ]
      },
      "csv": {
        "type": [
          "string",
          "null"
        ]
      },
      "state": {
        "type": [
          "string",
          "null"
        ]
      },
      "found_count": {
        "type": [
          "integer",
          "null"
        ],
        "minimum": 0
      },
      "fallback_reason": {
        "type": [
          "string",
          "null"
        ]
      }
    }
  }
}
