{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://powerpacks.local/schemas/search-network-jd-plan.schema.json",
  "title": "Deep Search Recruiter Plan",
  "description": "Reviewed recruiter contract created before deep-search retrieval.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "route",
    "parse_only",
    "retrieval_ran",
    "job_id",
    "job_title",
    "normalized_archetype",
    "source_url",
    "source_title",
    "set_scope",
    "search_scope",
    "hire_stage",
    "target_level",
    "usable_cutoff",
    "traits",
    "core_groups",
    "recruiter_policy",
    "created_at"
  ],
  "properties": {
    "route": {"const": "deep"},
    "parse_only": {"type": "boolean"},
    "retrieval_ran": {"const": false},
    "job_id": {"type": "string", "minLength": 1},
    "job_title": {"type": "string", "minLength": 1},
    "normalized_archetype": {"type": "string", "minLength": 1},
    "source_url": {"type": ["string", "null"]},
    "source_title": {"type": ["string", "null"]},
    "set_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "set_id"],
      "properties": {
        "name": {"type": "string"},
        "set_id": {"type": "string"}
      }
    },
    "search_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["location", "source"],
      "properties": {
        "location": {"type": ["string", "null"]},
        "source": {"enum": ["jd", "user", "default"]}
      }
    },
    "hire_stage": {"enum": ["founding_early", "scaling_late"]},
    "target_level": {
      "enum": ["senior_ic", "staff_ic", "lead", "manager", "director", "vp", "exec"]
    },
    "usable_cutoff": {"type": "string", "minLength": 1},
    "traits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["must_have", "nice_to_have"],
      "properties": {
        "must_have": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": {"$ref": "#/$defs/mustTrait"}
        },
        "nice_to_have": {
          "type": "array",
          "maxItems": 8,
          "items": {"$ref": "#/$defs/niceTrait"}
        }
      }
    },
    "core_groups": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/coreGroup"}
    },
    "recruiter_policy": {"$ref": "#/$defs/resolvedPolicy"},
    "created_at": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "mustTrait": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trait", "tier", "source"],
      "properties": {
        "trait": {"type": "string", "minLength": 1},
        "tier": {"enum": ["core", "table_stakes"]},
        "source": {"enum": ["jd", "user", "default"]}
      }
    },
    "niceTrait": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trait", "source"],
      "properties": {
        "trait": {"type": "string", "minLength": 1},
        "source": {"enum": ["jd", "user", "default"]}
      }
    },
    "coreGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "all_of", "source"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "all_of": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "source": {"enum": ["jd", "user", "default"]}
      }
    },
    "resolvedPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_id",
        "policy_version",
        "default_source",
        "precedence",
        "preferences",
        "provenance"
      ],
      "properties": {
        "policy_id": {"type": "string", "minLength": 1},
        "policy_version": {"type": "string", "minLength": 1},
        "default_source": {"type": "string", "minLength": 1},
        "precedence": {
          "type": "array",
          "prefixItems": [
            {"const": "user"},
            {"const": "jd"},
            {"const": "default"}
          ],
          "items": false,
          "minItems": 3,
          "maxItems": 3
        },
        "preferences": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "hire_stage",
            "evidence_priority",
            "excellence_weights",
            "pedigree_policy",
            "current_founder_c_suite_for_non_exec_ic",
            "higher_hands_on_ic",
            "fairness"
          ],
          "properties": {
            "hire_stage": {"enum": ["founding_early", "scaling_late"]},
            "evidence_priority": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {"type": "string", "minLength": 1}
            },
            "excellence_weights": {
              "type": "object",
              "additionalProperties": false,
              "required": ["trajectory", "impact", "pedigree"],
              "properties": {
                "trajectory": {"type": "number", "minimum": 0, "maximum": 1},
                "impact": {"type": "number", "minimum": 0, "maximum": 1},
                "pedigree": {"type": "number", "minimum": 0, "maximum": 1}
              }
            },
            "pedigree_policy": {"enum": ["positive_prior_not_gate", "ignore"]},
            "current_founder_c_suite_for_non_exec_ic": {
              "enum": ["default_out", "eligible", "review"]
            },
            "higher_hands_on_ic": {"const": "eligible"},
            "fairness": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "job_related_evidence_only",
                "exclude_protected_attributes",
                "exclude_protected_attribute_proxies"
              ],
              "properties": {
                "job_related_evidence_only": {"const": true},
                "exclude_protected_attributes": {"const": true},
                "exclude_protected_attribute_proxies": {"const": true}
              }
            }
          }
        },
        "provenance": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {"$ref": "#/$defs/provenance"}
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "default_source"],
      "properties": {
        "source": {"enum": ["user", "jd", "default"]},
        "default_source": {"type": "string", "minLength": 1},
        "derived_from": {"type": "string", "minLength": 1}
      }
    }
  }
}
