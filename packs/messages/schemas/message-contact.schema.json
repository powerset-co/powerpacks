{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://powerpacks/packs/messages/schemas/message-contact.schema.json",
  "title": "MessageContact",
  "type": "object",
  "additionalProperties": false,
  "required": ["phone", "name", "sources", "skip"],
  "properties": {
    "phone": {
      "type": "string",
      "pattern": "^\\+?[0-9]{7,15}$"
    },
    "name": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["imessage", "whatsapp"]
      },
      "uniqueItems": true
    },
    "is_in_group_chats": {
      "type": "boolean"
    },
    "group_names": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "message_count": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "last_message": {
      "type": ["string", "null"]
    },
    "skip": {
      "type": "boolean"
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": ["string", "null"],
          "enum": ["matched", "suggested", "unmatched", null]
        },
        "person_id": {
          "type": ["string", "null"]
        },
        "name": {
          "type": ["string", "null"]
        },
        "linkedin_url": {
          "type": ["string", "null"]
        },
        "confidence": {
          "type": ["number", "null"]
        },
        "method": {
          "type": ["string", "null"]
        },
        "reason": {
          "type": ["string", "null"]
        }
      }
    }
  }
}
