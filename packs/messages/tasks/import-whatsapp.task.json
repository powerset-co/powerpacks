{
  "task": "import_whatsapp",
  "version": 3,
  "description": "Import WhatsApp contacts through the local openclaw/wacli helper. No contact-exporter or WAHA dependency by default.",
  "default_constraints": {
    "no_message_content": true,
    "workflow_consent_can_cover_extraction": true,
    "extraction_requires_explicit_user_request": true
  },
  "steps": [
    {
      "id": "import_whatsapp_wacli",
      "display": "Sync WhatsApp",
      "kind": "primitive",
      "primitive": "import_whatsapp_wacli",
      "command": "run",
      "requires_explicit_user_request": true,
      "user_action": "Scan the browser QR page with WhatsApp > Settings > Linked Devices when needed."
    },
    {
      "id": "normalize_contacts",
      "kind": "primitive",
      "primitive": "normalize_message_contacts",
      "output_schema": "message-contact.schema.json"
    },
    {
      "id": "merge_contacts",
      "kind": "primitive",
      "primitive": "merge_message_contacts",
      "command": "merge",
      "description": "Dedupe with imessage.contacts.csv (if present) into a single contacts.csv."
    }
  ]
}
