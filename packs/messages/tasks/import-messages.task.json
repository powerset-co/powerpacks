{
  "task": "import_messages",
  "version": 1,
  "description": "Plan and execute a local-first iMessage/WhatsApp contact import through powerset-contacts and Powerpacks normalization.",
  "default_constraints": {
    "no_message_content": true,
    "local_extraction_only": true,
    "upload_requires_explicit_user_request": true,
    "prefer_bare_imessage_primitive": true
  },
  "steps": [
    {
      "id": "check_imessage",
      "kind": "primitive",
      "primitive": "extract_imessage_contacts"
    },
    {
      "id": "extract_imessage",
      "kind": "primitive",
      "primitive": "extract_imessage_contacts",
      "requires_explicit_user_request": true
    },
    {
      "id": "normalize_contacts",
      "kind": "primitive",
      "primitive": "normalize_message_contacts",
      "output_schema": "message-contact.schema.json"
    },
    {
      "id": "compat_review_or_whatsapp",
      "kind": "primitive",
      "primitive": "powerset_contacts_harness",
      "optional": true,
      "note": "Compatibility backend until WhatsApp/review/upload are ported to bare primitives."
    },
    {
      "id": "upload_contacts",
      "kind": "primitive",
      "primitive": "powerset_contacts_harness",
      "optional": true,
      "requires_explicit_user_request": true
    }
  ]
}
