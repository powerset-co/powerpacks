{
  "task": "import_contacts",
  "version": 1,
  "description": "One-command guided import of iMessage and WhatsApp contact metadata, followed by Powerset candidate sync, local matching, and review queue preparation.",
  "default_constraints": {
    "no_message_content": true,
    "local_metadata_consent_can_cover_extraction": true,
    "network_candidate_sync_allowed_after_initial_consent": true,
    "llm_review_requires_cost_approval_over_usd": 1.0,
    "llm_review_under_threshold_allowed_model": "anthropic/claude-sonnet-4-6",
    "deep_research_requires_cost_approval": true,
    "upload_requires_explicit_user_request": true
  },
  "state_path": ".powerpacks/messages/import-run.json",
  "steps": [
    {
      "id": "check_imessage",
      "kind": "primitive",
      "primitive": "extract_imessage_contacts",
      "command": "check"
    },
    {
      "id": "extract_imessage",
      "kind": "primitive",
      "primitive": "extract_imessage_contacts",
      "command": "extract",
      "requires_initial_workflow_consent": true,
      "blocked_by": "macOS Full Disk Access or Contacts permission"
    },
    {
      "id": "normalize_imessage",
      "kind": "primitive",
      "primitive": "normalize_message_contacts",
      "command": "normalize"
    },
    {
      "id": "check_docker_and_waha",
      "display": "Get WhatsApp sync ready",
      "kind": "primitive",
      "primitive": "waha_runtime",
      "command": "check"
    },
    {
      "id": "start_waha_container",
      "display": "Start WhatsApp sync",
      "kind": "primitive",
      "primitive": "waha_runtime",
      "command": "up",
      "requires_initial_workflow_consent": true,
      "docker_install_requires_explicit_user_request": true
    },
    {
      "id": "authenticate_whatsapp",
      "display": "Connect WhatsApp",
      "kind": "primitive",
      "primitive": "waha_session",
      "command": "start",
      "args": {"open": true, "wait": true},
      "user_action": "Scan the QR with WhatsApp > Settings > Linked Devices when needed."
    },
    {
      "id": "extract_whatsapp",
      "display": "Sync WhatsApp",
      "kind": "primitive",
      "primitive": "extract_whatsapp_contacts",
      "command": "extract",
      "requires_initial_workflow_consent": true
    },
    {
      "id": "normalize_whatsapp",
      "display": "Prepare WhatsApp contacts",
      "kind": "primitive",
      "primitive": "normalize_message_contacts",
      "command": "normalize"
    },
    {
      "id": "merge_contacts",
      "kind": "primitive",
      "primitive": "merge_message_contacts",
      "command": "merge"
    },
    {
      "id": "sync_powerset_candidates",
      "kind": "primitive",
      "primitive": "sync_powerset_candidates",
      "command": "sync"
    },
    {
      "id": "match_local_contacts",
      "kind": "primitive",
      "primitive": "match_local_candidates",
      "command": "match"
    },
    {
      "id": "prepare_research_queue",
      "kind": "primitive",
      "primitive": "prepare_research_queue",
      "command": "prepare"
    },
    {
      "id": "estimate_research_cost",
      "kind": "primitive",
      "primitive": "deep_research_contacts",
      "command": "estimate",
      "optional": true
    },
    {
      "id": "deep_research",
      "kind": "primitive",
      "primitive": "deep_research_contacts",
      "command": "run",
      "requires_explicit_user_request": true,
      "user_action": "Approve Parallel.ai spend after seeing the count and cost estimate. This approval is always required."
    },
    {
      "id": "build_review_csv",
      "kind": "primitive",
      "primitive": "build_research_review_csv",
      "command": "build",
      "optional": true
    },
    {
      "id": "review_research_web",
      "kind": "primitive",
      "primitive": "review_research_web",
      "command": "serve",
      "optional": true
    },
    {
      "id": "summarize_research_upload",
      "kind": "primitive",
      "primitive": "upload_research_review",
      "command": "summarize",
      "optional": true,
      "description": "Preview the reviewed artifact counts before any upload."
    },
    {
      "id": "upload_research_review",
      "kind": "primitive",
      "primitive": "upload_research_review",
      "command": "upload",
      "requires_explicit_user_request": true,
      "user_action": "Approve uploading the reviewed yes/no enrichment artifact to Powerset."
    },
    {
      "id": "review_contacts_web_fallback",
      "kind": "primitive",
      "primitive": "review_contacts_web",
      "command": "serve",
      "optional": true,
      "description": "Fallback raw contacts yes/no reviewer when Parallel is skipped, unavailable, or queue is empty."
    },
    {
      "id": "estimate_llm_review",
      "kind": "primitive",
      "primitive": "llm_review_contacts",
      "command": "estimate",
      "optional": true
    },
    {
      "id": "llm_review",
      "kind": "primitive",
      "primitive": "llm_review_contacts",
      "command": "review",
      "requires_explicit_user_request": "only when estimate >= $10.00 or model is not anthropic/claude-sonnet-4-6"
    }
  ]
}
