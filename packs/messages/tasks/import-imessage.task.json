{
  "task": "import_imessage",
  "version": 1,
  "description": "Import local iMessage contacts through Powerpacks primitives.",
  "default_constraints": {
    "no_message_content": true,
    "local_extraction_only": true,
    "upload_requires_explicit_user_request": true,
    "prefer_bare_imessage_primitive": true
  },
  "steps": [
    {
      "id": "check_imessage",
      "kind": "primitive",
      "primitive": "extract_imessage_contacts"
    },
    {
      "id": "extract_imessage",
      "kind": "primitive",
      "primitive": "extract_imessage_contacts",
      "requires_explicit_user_request": true
    },
    {
      "id": "normalize_contacts",
      "kind": "primitive",
      "primitive": "normalize_message_contacts",
      "output_schema": "message-contact.schema.json"
    },
    {
      "id": "merge_contacts",
      "kind": "primitive",
      "primitive": "merge_message_contacts",
      "command": "merge"
    }
  ]
}
