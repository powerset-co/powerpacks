# Powerset-hosted Powerpacks config.
# Copy to .env or source it before running hosted API/MCP/Auth0 commands.
# These values are public client/endpoint configuration, not secrets.

# Hosted search/provisioning API. Runtime keys are pulled from this host.
POWERPACKS_SEARCH_API_URL=https://search-api-7wk4uhe77q-uw.a.run.app
POWERPACKS_API_BASE_URL=https://search-api-7wk4uhe77q-uw.a.run.app
POWERSET_API_BASE=https://search-api-7wk4uhe77q-uw.a.run.app
POWERPACKS_API_URL=https://search-api-7wk4uhe77q-uw.a.run.app
POWERSET_API_URL=https://search-api-7wk4uhe77q-uw.a.run.app

# Include the trailing slash to avoid MCP clients retrying /mcp -> /mcp/.
POWERPACKS_MCP_URL=https://search-api-7wk4uhe77q-uw.a.run.app/mcp/

POWERPACKS_AUTH0_DOMAIN=aleph-mvp.us.auth0.com
POWERPACKS_AUTH0_CLIENT_ID=U7p09NWeJ0jy9M4GiaWa4cz0YVCdDVBl
# Auth0 audience identifier only; this is not the provisioning API base URL.
POWERPACKS_AUTH0_AUDIENCE=https://api.powerset.dev
POWERPACKS_AUTH0_SCOPES=openid profile email offline_access
