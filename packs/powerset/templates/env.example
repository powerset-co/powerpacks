# Powerset hosted API/MCP/Auth0 config (required for hosted commands).
# Leave blank for OSS/local-only use. Powerset-hosted users can copy
# packs/powerset/templates/env.powerset.example into .env.
POWERPACKS_API_URL=
POWERSET_API_URL=
POWERPACKS_SEARCH_API_URL=
POWERPACKS_API_BASE_URL=
POWERSET_API_BASE=
POWERPACKS_MCP_URL=
POWERPACKS_AUTH0_DOMAIN=
POWERPACKS_AUTH0_CLIENT_ID=
POWERPACKS_AUTH0_AUDIENCE=
POWERPACKS_AUTH0_SCOPES=openid profile email offline_access

# Powerpacks connector env
DATABASE_URL=
SUPABASE_DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
TURBOPUFFER_API_KEY=
TURBOPUFFER_REGION=gcp-us-central1
OPENAI_API_KEY=
OPENROUTER_API_KEY=
PARALLEL_API_KEY=
POWERPACKS_DEFAULT_SET_ID=
# Legacy alias also supported by search primitives.
POWERSET_DEFAULT_SET_ID=
# RapidAPI: split per-product. RAPIDAPI_KEY is the legacy fallback that
# Legacy clients may still consult this when the product-specific key is unset.
RAPIDAPI_KEY=
RAPIDAPI_LINKEDIN_KEY=
RAPIDAPI_TWITTER_KEY=
