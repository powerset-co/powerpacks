{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://powerpacks/schemas/task-run.schema.json",
  "title": "TaskRun",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "task", "status", "query", "created_at", "updated_at", "steps"],
  "properties": {
    "task_id": { "type": "string" },
    "task": {
      "type": "string",
      "enum": ["search_network"]
    },
    "status": {
      "type": "string",
      "enum": ["running", "awaiting_approval", "completed", "failed", "paused"]
    },
    "query": { "type": "string" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "constraints": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "plan": {
      "type": "object"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "recorded_at"],
        "properties": {
          "id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "completed", "failed", "skipped"]
          },
          "recorded_at": { "type": "string" },
          "elapsed_ms": { "type": "integer" },
          "output": {},
          "note": { "type": "string" }
        }
      }
    },
    "planned_steps": {
      "type": "array",
      "description": "Mutable checklist of the intended plan. The append-only steps array remains the execution log.",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "status"],
        "properties": {
          "id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "completed", "failed", "skipped"]
          },
          "planned_at": { "type": "string" },
          "started_at": { "type": "string" },
          "completed_at": { "type": "string" },
          "updated_at": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    },
    "summary": {
      "type": "object"
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "changes_requested"]
        },
        "requested_at": { "type": "string" },
        "approved_at": { "type": "string" },
        "changed_at": { "type": "string" },
        "approved_by": { "type": "string" },
        "requested_by": { "type": "string" },
        "execution_mode": {
          "type": "string",
          "enum": ["search_only", "rerank"]
        },
        "reason": { "type": "string" },
        "proposed_next_step": { "type": "string" },
        "note": { "type": "string" },
        "plan": { "type": "object" }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "task_id": { "type": "string" },
        "query": { "type": "string" },
        "state": { "type": "string" },
        "created_at": { "type": "string" },
        "artifact_dir": { "type": "string" },
        "csv": { "type": "string" },
        "jsonl": { "type": "string" },
        "manifest": { "type": "string" },
        "row_count": { "type": "integer" },
        "hydrated_count": { "type": "integer" },
        "frontier_count": { "type": "integer" },
        "agentic_candidate_review": {
          "type": "object",
          "additionalProperties": true,
          "description": "Sharded review manifest, shard paths, expected output paths, and final ranked artifacts."
        }
      }
    }
  }
}
