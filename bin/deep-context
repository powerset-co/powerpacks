#!/usr/bin/env bash
# Thin runner for the deep-context dossier pipeline.
#
# Run this DIRECTLY in your own terminal (e.g. Ghostty with Full Disk Access).
# It only chains the existing primitives in order — no logic of its own — so the
# work runs under your terminal's TCC grant and can actually read chat.db. The
# Claude Code Bash tool spawns commands under a helper process that does NOT
# inherit your terminal's Full Disk Access, which is why iMessage reads fail there.
#
# Usage:
#   bin/deep-context dry           # synthesize --dry-run against collected bundles
#   bin/deep-context run           # safety guard; paid stages must be run separately
#   bin/deep-context collect --limit 20
#   bin/deep-context lookup --name "Jane Doe"
#   bin/deep-context lookup --phone "+1 415 555 1234"
#
# Reads message BODIES (Gmail + iMessage/WhatsApp DMs, plus small iMessage groups
# only after explicit opt-in). Raw bundles are ephemeral + gitignored.

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

PY=(uv run --project . python -m)
PKG="packs.ingestion.primitives.deep_context"

usage() {
  cat >&2 <<'USAGE'
usage: bin/deep-context <command> [args]

  owner        build owner.json from YOUR LinkedIn (run first)
  check        readiness check (sources, Full Disk Access, keys)
  dry          estimate synthesis cost from existing raw bundles (free)
  run          safety guard: paid stages require separate previews and approvals
  collect      gather message bodies into raw bundles (free, local)
  synthesize   build per-person facts from bundles (spends OpenAI)
  compose      render dossiers from facts (free)
  cluster      LLM-judge same-person merge (spends OpenAI)
  parents      build canonical parent dossiers (free)
  validate     completeness report (free)
  reconcile    verify each attached LinkedIn (spends OpenAI; try --dry-run first)
  review       open the staged people / LinkedIn decision UI (local, free)
  review-agent manage the optional same-thread Codex wake bridge
  review-status  read manifests/CSVs and print the exact next workflow action
  assemble-synthetic  build synthetic people-rows from deep-research output for
               people with NO real LinkedIn (free, local; approved rows merge)
  profile-prefetch  preview/fetch cached profiles for LinkedIn review
               (default dry run; --fetch spends RapidAPI + OpenAI)
  rejudge      re-run synthesis worth for every message-backed dossier, ignoring
               cached machine/human decisions (spends OpenAI; try --dry-run first).
               Human network_worth cells remain untouched; LinkedIn is never evidence.
  reconcile-deep-research   find the right LinkedIn for detaches (Parallel.ai, $-gated)
  apply-retargets           enrich approved retargets -> retarget-people.csv
  realize      fan-in merge applying your decisions (free, local)
  lookup       fetch a person's dossier by name/phone/email
  probe        chat.db readability (Full Disk Access) check
  purge-raw    delete the ephemeral raw bundles

Pass --help after a single-step command (e.g. `collect --help`) for its flags.
USAGE
}

cmd="${1:-}"; shift || true

# Bare help request or no command: print usage, run nothing.
case "$cmd" in
  -h|--help|help|"") usage; exit 0 ;;
esac

# Did the user ask for help on this command? The guarded commands must not execute
# just because a delegated primitive accepted --help. Detect it explicitly.
wants_help=0
for _a in "$@"; do
  if [[ "$_a" == "-h" || "$_a" == "--help" ]]; then wants_help=1; fi
done

case "$cmd" in
  owner)
    # Step 0: build owner.json (YOUR bio) from your LinkedIn, cache-first. Run this FIRST so
    # synthesis + the LinkedIn judge can infer shared school/employer/era with each contact.
    "${PY[@]}" "$PKG.build_owner" "$@"
    ;;
  check)
    "${PY[@]}" "$PKG.check_readiness" "$@"
    ;;
  dry)
    if (( wants_help )); then
      echo "bin/deep-context dry - estimate synthesis cost from existing raw bundles." >&2
      echo "Run 'bin/deep-context collect' with the approved scope first." >&2
      exit 0
    fi
    "${PY[@]}" "$PKG.synthesize_person_context" --dry-run "$@"
    echo "Review estimated_cost_floor_usd / ceiling; after explicit approval run:" >&2
    printf "  bin/deep-context synthesize" >&2
    if (( $# )); then
      printf " %q" "$@" >&2
    fi
    printf "\n" >&2
    ;;
  collect)
    "${PY[@]}" "$PKG.collect_person_context" "$@"
    ;;
  synthesize)
    "${PY[@]}" "$PKG.synthesize_person_context" "$@"
    ;;
  run)
    if (( wants_help )); then
      echo "bin/deep-context run is disabled because paid stages require" >&2
      echo "separate previews and approvals. Follow the staged SKILL.md flow." >&2
      exit 0
    fi
    echo "bin/deep-context run is intentionally disabled: one chained command cannot" >&2
    echo "pause for the required synthesis, cluster, and reconcile cost approvals." >&2
    echo "Follow packs/ingestion/skills/deep-context/SKILL.md and run each staged" >&2
    echo "preview/approval/execute command separately." >&2
    exit 2
    ;;
  parents)
    "${PY[@]}" "$PKG.build_parents" "$@"
    ;;
  validate)
    "${PY[@]}" "$PKG.validate_dossiers" "$@"
    ;;
  compose)
    "${PY[@]}" "$PKG.compose_dossier" "$@"
    ;;
  cluster)
    "${PY[@]}" "$PKG.cluster_merge_candidates" "$@"
    ;;
  reconcile)
    # Phase 3: verify each parent against its attached LinkedIn (self-heal).
    # Use `reconcile --dry-run` for a free cost estimate first.
    "${PY[@]}" "$PKG.reconcile_linkedin" "$@"
    ;;
  assemble-synthetic)
    # Free, local: build synthetic people-rows from EXISTING deep-research artifacts
    # for people with no real LinkedIn (see packs/ingestion/docs/synthetic-profiles-plan.md).
    # A legacy approved=auto value is only machine advice in the staged flow; every
    # candidate-origin row still waits for explicit Yes/No in the LinkedIn UI.
    "${PY[@]}" "$PKG.assemble_synthetic_profile" "$@"
    ;;
  profile-prefetch)
    # Cache-only LinkedIn review is prepared by this explicit task. Default is a
    # free preview; --fetch crosses the RapidAPI + OpenAI approval boundary.
    "${PY[@]}" "$PKG.prefetch_profiles" "$@"
    ;;
  rejudge|re-review)
    # The old re-review alias is kept for scripts, but now uses the sole worth judge:
    # message synthesis. --rejudge selects every dossier regardless of cached
    # machine/human decisions; the mirror never overwrites network_worth.
    if [[ "$cmd" == "re-review" ]]; then
      echo "warning: 're-review' is deprecated; use 'bin/deep-context rejudge'" >&2
    fi
    "${PY[@]}" "$PKG.synthesize_person_context" --rejudge "$@"
    ;;
  review)
    # The UI remains file-driven. When Codex supplied its current thread id,
    # start/replace the fixed local bridge that wakes this same thread only
    # after a durable UI mutation reaches an actionable review-status state.
    if (( ! wants_help )) && [[ -n "${CODEX_THREAD_ID:-}" ]]; then
      if ! "${PY[@]}" "$PKG.review_agent_bridge" start; then
        echo "warning: same-thread review bridge did not start; use review-status polling" >&2
      fi
    fi
    "${PY[@]}" "$PKG.reconcile_review_web" serve --open "$@"
    ;;
  review-agent)
    "${PY[@]}" "$PKG.review_agent_bridge" "$@"
    ;;
  review-status)
    # Read-only deterministic poll target. No browser, provider, subprocess, or write.
    # Prefer the already-provisioned repo interpreter so a background Codex
    # bridge does not need write access to uv's user-level cache just to read
    # the fixed review manifests. Keep uv as the setup fallback.
    if [[ -x "$ROOT/.venv/bin/python" ]]; then
      "$ROOT/.venv/bin/python" -m "$PKG.reconcile_review_web" status "$@"
    else
      "${PY[@]}" "$PKG.reconcile_review_web" status "$@"
    fi
    ;;
  reconcile-deep-research)
    # Find the right identity for high-confidence wrong_person detaches. Every
    # Parallel.ai run needs an estimate, explicit approval, and approved budget.
    "${PY[@]}" "$PKG.reconcile_deep_research" "$@"
    ;;
  apply-retargets)
    # Enrich + build re-attach rows for approved `retarget` decisions -> retarget-people.csv,
    # which the fan-in merge auto-ingests. Cache-first (RapidAPI only on a miss).
    "${PY[@]}" "$PKG.apply_retargets" "$@"
    ;;
  realize)
    # Phase 4 (free, local): fan-in merge -> rebuilds merged/people.csv, auto-applying your
    # decisions (overrides/review.csv + consolidate/retarget). Borrows $setup's fan-in.
    # Then rebuild search on Modal yourself: linkedin_modal_pipeline.py index-people (spend, ~5-30m).
    uv run --project . python packs/indexing/primitives/index_contacts_pipeline/index_contacts_pipeline.py fan-in \
      --people-csv .powerpacks/network-import/merged/people.csv "$@"
    echo "✅ people.csv rebuilt with your decisions applied. Now rebuild search on Modal:" >&2
    echo "   uv run --project . python packs/indexing/modal/linkedin_modal_pipeline.py index-people --people-csv .powerpacks/network-import/merged/people.csv" >&2
    ;;
  lookup)
    "${PY[@]}" "$PKG.lookup_person" "$@"
    ;;
  probe)
    # Definitive chat.db readability check (Full Disk Access diagnosis).
    uv run --project . python -c "from packs.ingestion.primitives.deep_context import sources; import json, pathlib; print(json.dumps(sources.probe_chat_db(pathlib.Path.home()/'Library'/'Messages'/'chat.db'), indent=2))"
    ;;
  purge-raw)
    rm -rf .powerpacks/deep-context/raw
    echo "🧹 purged raw message bundles" >&2
    ;;
  *)
    echo "bin/deep-context: unknown command '$cmd'" >&2
    usage
    exit 2
    ;;
esac
