#!/usr/bin/env bash
# Thin runner for the deep-context dossier pipeline.
#
# Run this DIRECTLY in your own terminal (e.g. Ghostty with Full Disk Access).
# It only chains the existing primitives in order — no logic of its own — so the
# work runs under your terminal's TCC grant and can actually read chat.db. The
# Claude Code Bash tool spawns commands under a helper process that does NOT
# inherit your terminal's Full Disk Access, which is why iMessage reads fail there.
#
# Usage:
#   bin/deep-context dry           # collect (free) + synthesize --dry-run (cost estimate)
#   bin/deep-context run           # full pipeline: collect -> synthesize -> compose -> cluster
#   bin/deep-context run --limit 20    # cap people (passed to collect)
#   bin/deep-context lookup --name "Jane Doe"
#   bin/deep-context lookup --phone "+1 415 555 1234"
#
# Reads message BODIES (Gmail + iMessage/WhatsApp DMs) — that deep inspection is
# the whole point. DMs only; raw bundles are ephemeral + gitignored.

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

PY=(uv run --project . python -m)
PKG="packs.ingestion.primitives.deep_context"

cmd="${1:-}"; shift || true

case "$cmd" in
  owner)
    # Step 0: build owner.json (YOUR bio) from your LinkedIn, cache-first. Run this FIRST so
    # synthesis + the LinkedIn judge can infer shared school/employer/era with each contact.
    "${PY[@]}" "$PKG.build_owner" "$@"
    ;;
  check)
    "${PY[@]}" "$PKG.check_readiness" "$@"
    ;;
  dry)
    "${PY[@]}" "$PKG.collect_person_context" "$@"
    "${PY[@]}" "$PKG.synthesize_person_context" --dry-run
    echo "↑ review estimated_cost_floor_usd / ceiling, then run: bin/deep-context run" >&2
    ;;
  collect)
    "${PY[@]}" "$PKG.collect_person_context" "$@"
    ;;
  synthesize)
    "${PY[@]}" "$PKG.synthesize_person_context" "$@"
    ;;
  run)
    # Full pipeline incl. the Phase 3 self-heal (reconcile writes the durable override).
    # Spends OpenAI (synthesis + reconcile). Deep research / apply-retargets stay separate
    # (they need PARALLEL_API_KEY / your approval).
    "${PY[@]}" "$PKG.collect_person_context" "$@"
    "${PY[@]}" "$PKG.synthesize_person_context"
    "${PY[@]}" "$PKG.compose_dossier"
    "${PY[@]}" "$PKG.cluster_merge_candidates"
    "${PY[@]}" "$PKG.build_parents"
    "${PY[@]}" "$PKG.validate_dossiers"
    "${PY[@]}" "$PKG.reconcile_linkedin"
    echo "✅ dossiers + parents/ + reconcile self-heal in .powerpacks/deep-context/" >&2
    echo "   REVIEW: bin/deep-context review   (opens the self-heal review UI — keep / detach / fix each link)" >&2
    echo "   realize the heal on your next fan-in merge + Modal index rebuild (auto-reads the override)." >&2
    ;;
  parents)
    "${PY[@]}" "$PKG.build_parents" "$@"
    ;;
  validate)
    "${PY[@]}" "$PKG.validate_dossiers" "$@"
    ;;
  compose)
    "${PY[@]}" "$PKG.compose_dossier" "$@"
    ;;
  cluster)
    "${PY[@]}" "$PKG.cluster_merge_candidates" "$@"
    ;;
  reconcile)
    # Phase 3: verify each parent against its attached LinkedIn (self-heal).
    # Use `reconcile --dry-run` for a free cost estimate first.
    "${PY[@]}" "$PKG.reconcile_linkedin" "$@"
    ;;
  review)
    # Phase 3 review UI (local, free): a parent-grouped web view of the self-heal —
    # each row is a person; expand to see the LinkedIn(s) we matched, the reasoning, and
    # who got verified/detached. Keep / detach / fix each link; autosaves straight into
    # overrides/review.csv (the same table the fan-in merge re-applies). Opens your browser.
    "${PY[@]}" "$PKG.reconcile_review_web" serve --open "$@"
    ;;
  reconcile-deep-research)
    # Find the right identity for high-confidence wrong_person detaches (Parallel.ai,
    # $25 auto-approve gate). Reads reconcile verdicts written by `reconcile`.
    "${PY[@]}" "$PKG.reconcile_deep_research" "$@"
    ;;
  apply-retargets)
    # Enrich + build re-attach rows for approved `retarget` decisions -> retarget-people.csv,
    # which the fan-in merge auto-ingests. Cache-first (RapidAPI only on a miss).
    "${PY[@]}" "$PKG.apply_retargets" "$@"
    ;;
  realize)
    # Phase 4 (free, local): fan-in merge -> rebuilds merged/people.csv, auto-applying your
    # decisions (overrides/review.csv + consolidate/retarget). Borrows $setup's fan-in.
    # Then rebuild search on Modal yourself: linkedin_modal_pipeline.py index-people (spend, ~5-30m).
    uv run --project . python packs/indexing/primitives/index_contacts_pipeline/index_contacts_pipeline.py fan-in \
      --people-csv .powerpacks/network-import/merged/people.csv "$@"
    echo "✅ people.csv rebuilt with your decisions applied. Now rebuild search on Modal:" >&2
    echo "   uv run --project . python packs/indexing/modal/linkedin_modal_pipeline.py index-people --people-csv .powerpacks/network-import/merged/people.csv" >&2
    ;;
  lookup)
    "${PY[@]}" "$PKG.lookup_person" "$@"
    ;;
  probe)
    # Definitive chat.db readability check (Full Disk Access diagnosis).
    uv run --project . python -c "from packs.ingestion.primitives.deep_context import sources; import json, pathlib; print(json.dumps(sources.probe_chat_db(pathlib.Path.home()/'Library'/'Messages'/'chat.db'), indent=2))"
    ;;
  purge-raw)
    rm -rf .powerpacks/deep-context/raw
    echo "🧹 purged raw message bundles" >&2
    ;;
  *)
    echo "usage: bin/deep-context {owner|check|dry|run|collect|synthesize|compose|cluster|parents|reconcile|review|reconcile-deep-research|apply-retargets|validate|lookup|probe|purge-raw} [args]" >&2
    exit 2
    ;;
esac
