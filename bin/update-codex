#!/usr/bin/env bash
# Refresh this checkout and reinstall Powerpacks into Codex.
#
# Intended for agent-native use:
#   codex exec "cd /path/to/powerpacks && bin/update-codex"
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SKILLS_DIR="${1:-}"

cd "$ROOT"

if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  stashed=""
  if [[ -n "$(git status --short --porcelain=v1)" ]]; then
    stash_name="update-codex $(date +%Y-%m-%dT%H:%M:%S)"
    echo "Stashing local changes before update: $stash_name" >&2
    git stash push -u -m "$stash_name"
    stashed="$stash_name"
  fi

  if git fetch --quiet origin main; then
    if git show-ref --verify --quiet refs/heads/main; then
      git switch main
    else
      git switch -c main --track origin/main
    fi
    git pull --ff-only origin main
  else
    echo "warning: git fetch failed; continuing with the current checkout." >&2
  fi

  if [[ -n "$stashed" ]]; then
    echo "Local changes were left in git stash: $stashed" >&2
  fi
else
  echo "warning: $ROOT is not a git checkout; skipping git pull." >&2
fi

"$ROOT/bin/sync-agent-files.sh"

if [[ -n "$SKILLS_DIR" ]]; then
  "$ROOT/install.sh" codex "$SKILLS_DIR"
else
  "$ROOT/install.sh" codex
fi

echo
echo "Powerpacks Codex update complete. Restart Codex to reload installed skills."
