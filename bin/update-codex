#!/usr/bin/env bash
# Refresh this checkout and reinstall Powerpacks into Codex.
#
# Intended for agent-native use:
#   codex exec "cd /path/to/powerpacks && bin/update-codex"
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SKILLS_DIR="${1:-}"

cd "$ROOT"

if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  if ! git diff --quiet || ! git diff --cached --quiet; then
    echo "warning: working tree has local changes; git pull may stop if files overlap." >&2
  fi
  if git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
    git pull --ff-only
  else
    echo "warning: no upstream branch configured; skipping git pull." >&2
  fi
else
  echo "warning: $ROOT is not a git checkout; skipping git pull." >&2
fi

"$ROOT/bin/sync-agent-files.sh"

if [[ -n "$SKILLS_DIR" ]]; then
  "$ROOT/install.sh" codex "$SKILLS_DIR"
else
  "$ROOT/install.sh" codex
fi

echo
echo "Powerpacks Codex update complete. Restart Codex to reload installed skills."
