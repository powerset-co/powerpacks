#!/usr/bin/env bash
# Deterministically move the canonical checkout onto its release channel and
# reinstall Powerpacks skills for exactly one agent harness.
set -euo pipefail

# Fingerprint of the code actually running, taken before any `cd` or checkout.
# It must be captured NOW rather than compared later: when this script is run
# straight out of the repo, the checkout rewrites this very file, so comparing
# it against itself afterwards would always look identical while the process
# keeps executing the old content.
SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)/$(basename "${BASH_SOURCE[0]}")"
SELF_FINGERPRINT="$(git hash-object "$SELF" 2>/dev/null || echo unknown)"

HARNESS="${1:-}"
SKILLS_DIR="${2:-}"

case "$HARNESS" in
  codex|claude-code|pi) ;;
  *)
    echo "usage: update-powerpacks <codex|claude-code|pi> [skills-dir]" >&2
    exit 2
    ;;
esac

stamp_candidates=()
case "$HARNESS" in
  codex)
    stamp_candidates+=(
      "${CODEX_HOME:-$HOME/.codex}/skills/.powerpacks-install.json"
      "${CODEX_HOME:-$HOME/.codex}/powerpacks/.powerpacks-install.json"
    )
    ;;
  claude-code)
    stamp_candidates+=("${CLAUDE_CONFIG_DIR:-$HOME/.claude}/skills/.powerpacks-install.json")
    ;;
  pi)
    stamp_candidates+=("${PI_HOME:-$HOME/.pi/agent}/skills/.powerpacks-install.json")
    ;;
esac

stamp_repo_roots=()
for stamp in "${stamp_candidates[@]}"; do
  [[ -f "$stamp" ]] || continue
  stamp_root="$(python3 - "$stamp" <<'PY'
import json
import sys

try:
    value = json.load(open(sys.argv[1], encoding="utf-8")).get("repo_root", "")
except (OSError, json.JSONDecodeError):
    value = ""
print(value if isinstance(value, str) else "")
PY
)"
  [[ -n "$stamp_root" ]] && stamp_repo_roots+=("$stamp_root")
done

SCRIPT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

is_powerpacks_repo() {
  local candidate="$1"
  [[ -n "$candidate" ]] || return 1
  [[ "$candidate" != *"/.codex/"* ]] || return 1
  [[ -d "$candidate/packs" && -f "$candidate/pyproject.toml" && -x "$candidate/install.sh" ]] || return 1
  git -C "$candidate" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

REPO=""
candidates=(
  "${POWERPACKS_REPO_ROOT:-}"
)
for stamp_root in "${stamp_repo_roots[@]:-}"; do
  [[ -n "$stamp_root" ]] && candidates+=("$stamp_root")
done
candidates+=("$PWD" "$HOME/powerpacks" "$HOME/workspace/powerpacks" "$SCRIPT_ROOT")
for candidate in "${candidates[@]}"; do
  if is_powerpacks_repo "$candidate"; then
    REPO="$(cd "$candidate" && pwd)"
    break
  fi
done

if [[ -z "$REPO" ]]; then
  echo "error: no canonical Powerpacks git checkout found" >&2
  exit 1
fi

cd "$REPO"

# Carried across the re-exec handoff so the second pass still reports where the
# first pass put the user's dirty work.
stash_commit="${POWERPACKS_UPDATE_STASH_COMMIT:-}"
stash_message="${POWERPACKS_UPDATE_STASH_MESSAGE:-}"
stash_ref="${POWERPACKS_UPDATE_STASH_REF:-none}"

report_exit() {
  local exit_code=$?
  if ((exit_code != 0)) && [[ -n "$stash_commit" ]]; then
    echo "recovery_stash_commit=$stash_commit" >&2
    echo "recovery_stash_ref=$stash_ref" >&2
    echo "recovery_stash_restored=false" >&2
  fi
  trap - EXIT
  exit "$exit_code"
}
trap report_exit EXIT

for protected_path in .powerpacks .env; do
  if git ls-files -- "$protected_path" | grep -q .; then
    echo "error: refusing to update because $protected_path contains tracked files" >&2
    exit 1
  fi
  if [[ -e "$protected_path" ]] && ! git check-ignore -q "$protected_path"; then
    echo "error: refusing to update because $protected_path is not ignored by Git" >&2
    exit 1
  fi
done

git remote get-url origin >/dev/null
# Where the user started, preserved across the handoff so the summary still
# reports the real before/after rather than the post-checkout state.
OLD_COMMIT="${POWERPACKS_UPDATE_OLD_COMMIT:-$(git rev-parse HEAD 2>/dev/null || echo "")}"
OLD_BRANCH="${POWERPACKS_UPDATE_OLD_BRANCH:-$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")}"
git fetch --prune origin main
git fetch --tags --force origin

# Which release does this checkout follow? bin/powerpacks-channel owns the whole
# answer (channel precedence + newest-tag selection) so the installer and this
# updater can never disagree about it.
CHANNEL=""
TARGET_REF=""
TARGET_BRANCH=""
while IFS='=' read -r key value; do
  case "$key" in
    channel) CHANNEL="$value" ;;
    ref) TARGET_REF="$value" ;;
    branch) TARGET_BRANCH="$value" ;;
  esac
done < <("$REPO/bin/powerpacks-channel" "$REPO")

if [[ -z "$CHANNEL" || -z "$TARGET_REF" || -z "$TARGET_BRANCH" ]]; then
  echo "error: could not resolve a release channel for $REPO" >&2
  exit 1
fi

for protected_path in .powerpacks .env; do
  if git ls-tree -r --name-only "$TARGET_REF" -- "$protected_path" | grep -q .; then
    echo "error: refusing to update because $TARGET_REF tracks $protected_path" >&2
    exit 1
  fi
done

if [[ -n "$(git status --porcelain=v1 --untracked-files=all)" ]]; then
  stash_message="update-powerpacks $(date -u +%Y-%m-%dT%H:%M:%SZ)"
  git stash push --include-untracked -m "$stash_message" >/dev/null
  stash_commit="$(git rev-parse refs/stash)"
  stash_ref='stash@{0}'
fi

# The stash above already emptied the tree, so the plain (non-forcing) checkout
# in powerpacks-channel is enough — and reusing it keeps the branch/upstream
# handling in one place.
"$REPO/bin/powerpacks-channel" --checkout "$REPO" >/dev/null
git reset --hard "$TARGET_REF" >/dev/null

# This updater is part of what it updates. The copy a harness installed can be
# older than the release just checked out, so every step below would run stale
# logic against a new tree — that is how a moved primitive path turns into a
# silent no-op instead of an error. Hand off to the updater that shipped with
# this release; the guard makes it exactly one handoff, never a loop.
#
# `exec` (not source) is the safe transfer: git replaces files rather than
# truncating them, so this process keeps reading its original inode until the
# moment it is replaced wholesale.
shipped_fingerprint="$(git hash-object "$REPO/bin/update-powerpacks" 2>/dev/null || echo unknown)"
if [[ -z "${POWERPACKS_UPDATE_REEXEC:-}" ]] \
  && [[ -x "$REPO/bin/update-powerpacks" ]] \
  && [[ "$SELF_FINGERPRINT" != "unknown" && "$shipped_fingerprint" != "unknown" ]] \
  && [[ "$SELF_FINGERPRINT" != "$shipped_fingerprint" ]]; then
  export POWERPACKS_UPDATE_REEXEC=1
  export POWERPACKS_UPDATE_OLD_COMMIT="$OLD_COMMIT"
  export POWERPACKS_UPDATE_OLD_BRANCH="$OLD_BRANCH"
  export POWERPACKS_UPDATE_STASH_COMMIT="$stash_commit"
  export POWERPACKS_UPDATE_STASH_MESSAGE="$stash_message"
  export POWERPACKS_UPDATE_STASH_REF="$stash_ref"
  echo "handing off to the updater shipped with $TARGET_REF" >&2
  exec "$REPO/bin/update-powerpacks" "$@"
fi

"$REPO/bin/sync-agent-files.sh"

case "$HARNESS" in
  codex)
    if [[ -n "$SKILLS_DIR" ]]; then
      POWERPACKS_SKIP_AGENT_BOOTSTRAP=1 "$REPO/install.sh" codex "$SKILLS_DIR"
      stamp_path="$SKILLS_DIR/.powerpacks-install.json"
    else
      POWERPACKS_SKIP_AGENT_BOOTSTRAP=1 "$REPO/install.sh" codex
      stamp_path="${CODEX_HOME:-$HOME/.codex}/skills/.powerpacks-install.json"
    fi
    ;;
  claude-code)
    if [[ -n "$SKILLS_DIR" ]]; then
      "$REPO/install.sh" claude-code "$SKILLS_DIR"
      stamp_path="$SKILLS_DIR/.powerpacks-install.json"
    else
      "$REPO/install.sh" claude-code
      stamp_path="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/skills/.powerpacks-install.json"
    fi
    ;;
  pi)
    if [[ -n "$SKILLS_DIR" ]]; then
      "$REPO/install.sh" pi "$SKILLS_DIR"
      stamp_path="$SKILLS_DIR/.powerpacks-install.json"
    else
      "$REPO/install.sh" pi
      stamp_path="${PI_HOME:-$HOME/.pi/agent}/skills/.powerpacks-install.json"
    fi
    ;;
esac

# Refresh the pinned wacli WhatsApp helper to the version this checkout pins, so
# $update-powerpacks is the single command that also brings the binary current
# (it downloads a prebuilt binary; a no-op when already at the pin). Best-effort:
# a download/network failure or unsupported platform must not fail the update.
wacli_refresh="skipped"
wacli_version="-"
wacli_primitive="$REPO/packs/ingestion/primitives/discover/messages/whatsapp_wacli.py"
if command -v uv >/dev/null 2>&1 && [[ -f "$wacli_primitive" ]]; then
  if wacli_out="$(uv run --project "$REPO" python "$wacli_primitive" ensure-wacli 2>/dev/null)"; then
    # action = "downloaded" (freshly fetched) or "current" (already at the pin)
    read -r wacli_refresh wacli_version < <(
      printf '%s' "$wacli_out" | python3 -c 'import sys, json
try:
    d = json.load(sys.stdin)
    print(d.get("action", "ok"), d.get("pinned_version", "-"))
except Exception:
    print("ok", "-")' 2>/dev/null
    )
    : "${wacli_refresh:=ok}"
  else
    wacli_refresh="failed"
  fi
fi

# Human summary FIRST: did anything change, and what. The key=value block
# below stays for scripts that parse it.
NEW_COMMIT="$(git rev-parse HEAD)"
NEW_VERSION="$("$REPO/bin/powerpacks-install-stamp" --print "$REPO" | sed -n 's/^version=//p')"
echo
if [[ -n "$OLD_COMMIT" && "$OLD_COMMIT" != "$NEW_COMMIT" ]]; then
  # left...right counts both directions: pinning to a release can legitimately
  # move a checkout BACKWARDS off an unreleased main, and that must not be
  # reported as "N new commits".
  span="$(git rev-list --left-right --count "$OLD_COMMIT...$NEW_COMMIT" 2>/dev/null || echo "? ?")"
  dropped="${span%%[[:space:]]*}"
  gained="${span##*[[:space:]]}"
  echo "✅ $CHANNEL $TARGET_REF (v$NEW_VERSION): ${OLD_COMMIT:0:7} -> ${NEW_COMMIT:0:7} (+$gained/-$dropped commit(s))"
  git log --oneline "$OLD_COMMIT..$NEW_COMMIT" 2>/dev/null | head -10 | sed 's/^/   /'
else
  echo "✅ already on $CHANNEL $TARGET_REF (v$NEW_VERSION) at ${NEW_COMMIT:0:7}"
fi
if [[ -n "$OLD_BRANCH" && "$OLD_BRANCH" != "$TARGET_BRANCH" ]]; then
  echo "   channel branch: $OLD_BRANCH -> $TARGET_BRANCH"
fi
echo
echo "status=ok"
echo "repo=$REPO"
echo "harness=$HARNESS"
echo "commit=$NEW_COMMIT"
echo "channel=$CHANNEL"
echo "ref=$TARGET_REF"
echo "version=$NEW_VERSION"
echo "stash_commit=${stash_commit:-none}"
echo "stash_ref=$stash_ref"
echo "stash_message=${stash_message:-none}"
echo "stash_restored=false"
echo "preserved=.powerpacks,.env"
echo "install_stamp=$stamp_path"
echo "wacli_refresh=$wacli_refresh"
echo "wacli_version=$wacli_version"
