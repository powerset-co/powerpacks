#!/usr/bin/env python3
"""Generic skill-eval harness.

Drives any installed Powerpacks skill through a host agent (Codex, Claude
Code, or any shell-invokable model command) and grades the agent's output
with an LLM judge against each case's `expected_behavior` rubric. Keyword
counting is intentionally not supported: it grades vocabulary, not
behavior, and rewards plans that parrot the right tokens while doing the
wrong thing.

Usage:
    scripts/run-skill-eval --skill powerset-login --mode dry-run
    scripts/run-skill-eval --skill sales-nav-search --mode live --host codex
    scripts/run-skill-eval --skill search-network --case '^stanford'

Modes:
    dry-run  (default)  Build the prompt, validate case structure, do NOT
                        invoke the agent or the judge. Cheap, CI-safe.
    live                Invoke the host agent per case, then grade each
                        output with the judge model. Costs model spend
                        (agent + one cheap judge call per case).

Hosts:
    codex     Default. Runs `codex exec < <prompt_file>`.
    claude    Runs `claude --print < <prompt_file>`.
    custom    Pass `--agent-command "<template>"` with placeholders
              {prompt_file}, {skill}, {skill_path}, {case_id}, {query}.

Judge:
    OpenAI chat completions via OPENAI_API_KEY (read from env or .env).
    Model: --judge-model, else $POWERPACKS_EVAL_JUDGE_MODEL, else a cheap
    default. The judge returns strict JSON {pass, violations, reasoning}.

Case file format (JSON array):
    [
      {
        "id": "fresh-machine",
        "query": "Set me up to use Powerpacks for the first time.",
        "expected_behavior": "The plan must start with browser-based
            gcloud auth and must never offer to skip the consent step.
            ...plain-language rubric of required and forbidden behavior."
      },
      ...
    ]

Cases live at one of:
    packs/<pack>/evals/<skill>/cases.json
    packs/<pack>/skills/<skill>/evals/cases.json

Stdlib only.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import shlex
import subprocess
import sys
import uuid
from dataclasses import dataclass, field
from datetime import datetime, timezone
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[1]
PACKS_DIR = ROOT / "packs"
DEFAULT_OUT_DIR = ROOT / ".powerpacks" / "skill-evals"

DEFAULT_AGENT_COMMANDS = {
    "codex": "codex exec < {prompt_file}",
    "claude": "claude --print < {prompt_file}",
}


# ---------------------------------------------------------------------------
# Case loading
# ---------------------------------------------------------------------------


@dataclass
class Case:
    id: str
    query: str
    expected_behavior: str = ""
    expected_tools: list[str] = field(default_factory=list)
    notes: str = ""


def find_skill(skill_name: str) -> tuple[Path, Path]:
    """Locate (skill_dir, skill_md) for `skill_name` under packs/."""
    candidates = list(PACKS_DIR.glob(f"*/skills/{skill_name}/SKILL.md"))
    if not candidates:
        raise FileNotFoundError(
            f"skill '{skill_name}' not found under {PACKS_DIR}/*/skills/"
        )
    if len(candidates) > 1:
        raise FileNotFoundError(
            f"skill '{skill_name}' is ambiguous: {[str(c) for c in candidates]}"
        )
    skill_md = candidates[0]
    return skill_md.parent, skill_md


def find_cases(skill_name: str, skill_dir: Path) -> Path:
    """Locate the cases.json for `skill_name`."""
    pack_dir = skill_dir.parent.parent  # packs/<pack>/skills/<skill> -> packs/<pack>
    candidates = [
        pack_dir / "evals" / skill_name / "cases.json",
        skill_dir / "evals" / "cases.json",
    ]
    for path in candidates:
        if path.is_file():
            return path
    raise FileNotFoundError(
        f"no cases.json for skill '{skill_name}'. Looked at:\n  "
        + "\n  ".join(str(c) for c in candidates)
    )


def load_cases(cases_path: Path) -> list[Case]:
    raw = json.loads(cases_path.read_text())
    if not isinstance(raw, list):
        raise ValueError(f"{cases_path}: expected a JSON array of cases")
    cases: list[Case] = []
    for i, entry in enumerate(raw):
        if not isinstance(entry, dict):
            raise ValueError(f"{cases_path}[{i}]: expected an object")
        if "id" not in entry or "query" not in entry:
            raise ValueError(f"{cases_path}[{i}]: missing required keys 'id' / 'query'")
        cases.append(
            Case(
                id=str(entry["id"]),
                query=str(entry["query"]),
                expected_behavior=str(entry.get("expected_behavior", "")).strip(),
                expected_tools=list(entry.get("expected_tools", [])),
                notes=str(entry.get("notes", "")),
            )
        )
    if not cases:
        raise ValueError(f"{cases_path}: case file is empty")
    return cases


def select_cases(cases: list[Case], pattern: str | None, max_cases: int | None) -> list[Case]:
    out = cases
    if pattern:
        rx = re.compile(pattern)
        out = [c for c in out if rx.search(c.id)]
    if max_cases is not None:
        out = out[:max_cases]
    return out


# ---------------------------------------------------------------------------
# Prompt construction
# ---------------------------------------------------------------------------


def build_prompt(skill_md: Path, case: Case) -> str:
    return (
        f"Use the Powerpacks `{skill_md.parent.name}` skill to handle the "
        f"following user request.\n\n"
        f"First READ the skill file at {skill_md} and treat that file as the "
        f"authoritative version of the skill. If a copy of this skill is "
        f"installed in your environment, ignore it — the repo file may be "
        f"newer.\n\n"
        f"User request:\n{case.query}\n\n"
        f"Walk through the skill's workflow as it applies to this request. "
        f"Reference the exact primitive / tool names from the skill body. "
        f"If a step requires approval, surface the approval prompt instead "
        f"of executing it."
    )


# ---------------------------------------------------------------------------
# Agent invocation
# ---------------------------------------------------------------------------


def invoke_agent(
    command_template: str,
    prompt_file: Path,
    skill_md: Path,
    case: Case,
    timeout_sec: int,
) -> tuple[int, str, str]:
    command = command_template.format(
        prompt_file=shlex.quote(str(prompt_file)),
        skill=shlex.quote(skill_md.parent.name),
        skill_path=shlex.quote(str(skill_md)),
        case_id=shlex.quote(case.id),
        query=shlex.quote(case.query),
    )
    completed = subprocess.run(
        command,
        shell=True,
        text=True,
        capture_output=True,
        cwd=str(ROOT),
        timeout=timeout_sec,
    )
    return completed.returncode, completed.stdout, completed.stderr


# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------


DEFAULT_JUDGE_MODEL = "gpt-5-mini"
JUDGE_SYSTEM_PROMPT = (
    "You are a strict grader of AI agent plans. You receive a user request, "
    "a rubric describing the expected behavior, and the agent's output. "
    "Grade whether the agent's plan satisfies the rubric in substance — "
    "judge what the plan would actually do, not whether it uses particular "
    "words. A plan that names the right tools but sequences them wrongly "
    "fails; a plan that describes the right behavior in different words "
    "passes. Return ONLY a JSON object: "
    '{"pass": true|false, "violations": ["..."], "reasoning": "<one short paragraph>"}'
)


def load_dotenv_key(name: str) -> str | None:
    if os.environ.get(name):
        return os.environ[name]
    env_file = ROOT / ".env"
    if not env_file.exists():
        return None
    for line in env_file.read_text().splitlines():
        line = line.strip()
        if line.startswith(f"{name}="):
            return line.split("=", 1)[1].strip().strip('"').strip("'")
    return None


def judge_output(case: Case, output: str, *, model: str, api_key: str) -> dict[str, Any]:
    """Grade agent output against the case rubric with an LLM judge."""
    import urllib.request

    user_prompt = (
        f"User request:\n{case.query}\n\n"
        f"Expected behavior rubric:\n{case.expected_behavior}\n\n"
        f"Agent output to grade:\n{output[:30000]}"
    )
    body = json.dumps({
        "model": model,
        "response_format": {"type": "json_object"},
        "messages": [
            {"role": "system", "content": JUDGE_SYSTEM_PROMPT},
            {"role": "user", "content": user_prompt},
        ],
    }).encode("utf-8")
    request = urllib.request.Request(
        "https://api.openai.com/v1/chat/completions",
        data=body,
        headers={"Content-Type": "application/json", "Authorization": f"Bearer {api_key}"},
    )
    try:
        with urllib.request.urlopen(request, timeout=120) as response:
            payload = json.loads(response.read().decode("utf-8"))
        verdict = json.loads(payload["choices"][0]["message"]["content"])
    except Exception as exc:
        return {"ok": False, "violations": [], "reasoning": f"judge call failed: {exc}", "judge_error": True}
    return {
        "ok": bool(verdict.get("pass")),
        "violations": [str(v) for v in verdict.get("violations") or []],
        "reasoning": str(verdict.get("reasoning") or ""),
        "judge_model": model,
    }


# ---------------------------------------------------------------------------
# Reporting
# ---------------------------------------------------------------------------


def now_iso() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def write_report(out_dir: Path, skill: str, mode: str, results: list[dict[str, Any]]) -> Path:
    report_path = out_dir / "report.md"
    total = len(results)
    passed = sum(1 for r in results if r["validation"]["ok"])
    lines = [
        f"# Skill eval: `{skill}`",
        "",
        f"- mode: `{mode}`",
        f"- generated: `{now_iso()}`",
        f"- cases: {passed}/{total} passed",
        "",
        "| case | ok | violations | judge reasoning |",
        "| --- | --- | --- | --- |",
    ]
    for r in results:
        v = r["validation"]
        ok = "✅" if v["ok"] else "❌"
        violations = "; ".join(v.get("violations") or []) or "—"
        reasoning = (v.get("reasoning") or "—").replace("|", "/").replace("\n", " ")[:300]
        lines.append(f"| `{r['id']}` | {ok} | {violations} | {reasoning} |")
    report_path.write_text("\n".join(lines) + "\n")
    return report_path


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__.split("\n")[0])
    parser.add_argument("--skill", required=True, help="Skill name, e.g. powerset-login")
    parser.add_argument("--mode", choices=("dry-run", "live"), default="dry-run")
    parser.add_argument("--host", choices=("codex", "claude", "custom"), default="codex")
    parser.add_argument("--agent-command", help="Custom shell command template (overrides --host)")
    parser.add_argument("--case", help="Regex to filter case ids")
    parser.add_argument("--max-cases", type=int)
    parser.add_argument("--out-dir", type=Path, help="Override output directory")
    parser.add_argument("--timeout-sec", type=int, default=300)
    parser.add_argument("--cases-file", type=Path, help="Override cases.json path")
    parser.add_argument("--json", action="store_true", help="Print summary as JSON")
    parser.add_argument(
        "--judge-model",
        default=os.environ.get("POWERPACKS_EVAL_JUDGE_MODEL") or DEFAULT_JUDGE_MODEL,
        help="OpenAI model used to grade agent output in live mode",
    )
    args = parser.parse_args()

    try:
        skill_dir, skill_md = find_skill(args.skill)
    except FileNotFoundError as e:
        print(f"error: {e}", file=sys.stderr)
        return 2

    try:
        cases_path = args.cases_file or find_cases(args.skill, skill_dir)
        cases = load_cases(cases_path)
    except (FileNotFoundError, ValueError) as e:
        print(f"error: {e}", file=sys.stderr)
        return 2

    selected = select_cases(cases, args.case, args.max_cases)
    if not selected:
        print(f"no cases matched filter (cases={len(cases)}, filter={args.case!r})", file=sys.stderr)
        return 2

    run_id = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ") + "-" + uuid.uuid4().hex[:8]
    out_dir = args.out_dir or (DEFAULT_OUT_DIR / args.skill / run_id)
    out_dir.mkdir(parents=True, exist_ok=True)

    if args.agent_command:
        command_template = args.agent_command
    elif args.host in DEFAULT_AGENT_COMMANDS:
        command_template = DEFAULT_AGENT_COMMANDS[args.host]
    else:
        print(f"error: --host=custom requires --agent-command", file=sys.stderr)
        return 2

    results: list[dict[str, Any]] = []
    for case in selected:
        case_dir = out_dir / case.id
        case_dir.mkdir(parents=True, exist_ok=True)
        prompt = build_prompt(skill_md, case)
        prompt_file = case_dir / "prompt.txt"
        prompt_file.write_text(prompt)

        if args.mode == "dry-run":
            # Dry-run: skip invocation; a case is structurally valid only if
            # it carries a judge rubric.
            ok = bool(case.expected_behavior)
            result = {
                "id": case.id,
                "query": case.query,
                "prompt_file": str(prompt_file),
                "mode": "dry-run",
                "validation": {
                    "ok": ok,
                    "violations": [] if ok else ["case is missing expected_behavior (judge rubric)"],
                    "reasoning": "dry-run structural check only",
                },
                "skipped": True,
            }
        else:
            if not case.expected_behavior:
                result = {
                    "id": case.id,
                    "query": case.query,
                    "mode": "live",
                    "validation": {
                        "ok": False,
                        "violations": ["case is missing expected_behavior (judge rubric)"],
                        "reasoning": "live grading requires an expected_behavior rubric",
                    },
                }
                (case_dir / "result.json").write_text(json.dumps(result, indent=2, sort_keys=True) + "\n")
                results.append(result)
                continue
            api_key = load_dotenv_key("OPENAI_API_KEY")
            if not api_key:
                print("error: live mode needs OPENAI_API_KEY (env or .env) for the judge", file=sys.stderr)
                return 2
            try:
                rc, stdout, stderr = invoke_agent(
                    command_template, prompt_file, skill_md, case, args.timeout_sec
                )
            except subprocess.TimeoutExpired:
                stdout = ""
                stderr = f"timeout after {args.timeout_sec}s"
                rc = 124
            (case_dir / "stdout.txt").write_text(stdout)
            (case_dir / "stderr.txt").write_text(stderr)
            (case_dir / "exit-code.txt").write_text(str(rc) + "\n")

            validation = judge_output(case, stdout, model=args.judge_model, api_key=api_key)
            result = {
                "id": case.id,
                "query": case.query,
                "exit_code": rc,
                "stdout_len": len(stdout),
                "validation": validation,
                "mode": "live",
            }
        (case_dir / "result.json").write_text(json.dumps(result, indent=2, sort_keys=True) + "\n")
        results.append(result)

    report_path = write_report(out_dir, args.skill, args.mode, results)

    summary = {
        "skill": args.skill,
        "mode": args.mode,
        "host": args.host,
        "out_dir": str(out_dir),
        "report": str(report_path),
        "cases_total": len(selected),
        "cases_passed": sum(1 for r in results if r["validation"]["ok"]),
    }
    if args.json:
        print(json.dumps(summary, indent=2))
    else:
        print(f"skill: {args.skill}")
        print(f"mode:  {args.mode}")
        print(f"out:   {out_dir}")
        print(f"cases: {summary['cases_passed']}/{summary['cases_total']} passed")
        print(f"report: {report_path}")
    return 0 if summary["cases_passed"] == summary["cases_total"] else 1


if __name__ == "__main__":
    raise SystemExit(main())
