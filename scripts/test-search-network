#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SEARCH_EVALS="$ROOT/packs/search/evals"
DEFAULT_APP_DIR="${APP_DIR:-$ROOT}"
DEFAULT_RECALL_DIR="${RECALL_DIR:-$DEFAULT_APP_DIR/tests/recall}"
DEFAULT_QUERY_DATASET_DIR="${QUERY_DATASET_DIR:-$DEFAULT_APP_DIR/tests/evals/query_expansion/datasets}"

require_recall_dir() {
  if [[ ! -d "$DEFAULT_RECALL_DIR" ]]; then
    cat >&2 <<EOF
error: recall fixtures not found: $DEFAULT_RECALL_DIR
Set RECALL_DIR=/path/to/tests/recall, or set APP_DIR=/path/to/repo that contains tests/recall.
EOF
    exit 2
  fi
}

require_query_dataset_dir() {
  if [[ ! -d "$DEFAULT_QUERY_DATASET_DIR" ]]; then
    cat >&2 <<EOF
error: query expansion dataset not found: $DEFAULT_QUERY_DATASET_DIR
Set QUERY_DATASET_DIR=/path/to/tests/evals/query_expansion/datasets, or set APP_DIR=/path/to/repo that contains it.
EOF
    exit 2
  fi
}

usage() {
  cat <<'EOF'
usage: scripts/test-search-network COMMAND [ARGS]

Commands:
  check
      Run local readiness checks: install Codex skills, lint, tests, and
      dry-run the parallel expansion pipeline and company-search harnesses.

  company-dry-run [--case-glob REGEX] [--max-cases N]
      Validate search-company contract cases without hitting TurboPuffer.

  company-live [--case-glob REGEX] [--max-cases N]
      Run search-company contract cases through resolve_investors and
      resolve_companies. This hits TurboPuffer/OpenAI when semantic company
      search is used.

  primitive-recall [--bucket BUCKET] [--case-glob REGEX] [--max-cases N]
      Run recall YAMLs through deterministic Powerpacks decomposition and
      primitives. This hits TurboPuffer/Postgres when cases execute.

  pipeline-eval [--bucket BUCKET] [--case-glob REGEX] [--max-cases N]
      Run recall YAMLs through expand_search_request + search_network_pipeline.
      Tests the full product flow: parallel query expansion → pipeline runs
      retrieval/hydration → recall checked. Defaults to --search-only
      (no LLM rerank) unless POWERPACKS_PIPELINE_SKIP_LLM=false.

  pipeline-eval-dry-run [--bucket BUCKET] [--case-glob REGEX] [--max-cases N]
      Write expansion artifacts for pipeline-eval without invoking expansion or
      pipeline.

  pipeline-eval-list [--bucket BUCKET] [--case-glob REGEX]
      List matching recall cases for pipeline-eval.

  component
      Run search-network component tests against local mocks/fixtures: mock
      OpenAI-compatible chat/embeddings, local DuckDB TurboPuffer backend, and
      JSON-backed Postgres fixture. No live credentials required.

  mock-prepare
      Backward-compatible alias for component.

Environment:
  APP_DIR                           Defaults to the Powerpacks repo root. Set this when using external fixtures.
  RECALL_DIR                        Defaults to $APP_DIR/tests/recall; recall/eval commands fail clearly if absent.
  QUERY_DATASET_DIR                 Defaults to $APP_DIR/tests/evals/query_expansion/datasets.
  ENV_FILE                          Retrieval primitive env file. Defaults to .env.
  LIMIT_CAP                         Defaults to 1000.
  POWERPACKS_PIPELINE_SKIP_LLM      Set to true/1 to skip LLM filter/rerank in pipeline-eval. Default: true.
  POWERPACKS_PIPELINE_SET_ID        Override set_id for pipeline-eval. Use to scope to an org set.
EOF
}

run_company_harness() {
  local mode="$1"
  shift
  local args=(
    uv run python "$SEARCH_EVALS/run_company_search_harness.py"
    --app-dir "$DEFAULT_APP_DIR"
    --env-file "${ENV_FILE:-.env}"
  )
  if [[ "$mode" == "live" ]]; then
    args+=(--live)
  fi
  args+=("$@")
  "${args[@]}"
}

command="${1:-}"
if [[ -n "$command" ]]; then
  shift
fi

case "$command" in
  check)
    "$ROOT/install.sh" codex
    "$ROOT/scripts/lint-powerpacks"
    "$ROOT/scripts/test-powerpacks"
    require_recall_dir
    uv run python "$SEARCH_EVALS/run_pipeline_eval.py" \
      --recall-dir "$DEFAULT_RECALL_DIR" \
      --env-file "${ENV_FILE:-.env}" \
      --limit-cap "${LIMIT_CAP:-10000}" \
      --dry-run --bucket education --max-cases 1
    run_company_harness dry
    ;;
  company-dry-run)
    run_company_harness dry "$@"
    ;;
  company-live)
    run_company_harness live "$@"
    ;;
  primitive-recall)
    require_recall_dir
    uv run python "$SEARCH_EVALS/run_recall_parity.py" \
      --app-dir "$DEFAULT_APP_DIR" \
      --recall-dir "$DEFAULT_RECALL_DIR" \
      --env-file "${ENV_FILE:-.env}" \
      --limit-cap "${LIMIT_CAP:-10000}" \
      "$@"
    ;;
  pipeline-eval)
    require_recall_dir
    uv run python "$SEARCH_EVALS/run_pipeline_eval.py" \
      --recall-dir "$DEFAULT_RECALL_DIR" \
      --env-file "${ENV_FILE:-.env}" \
      --limit-cap "${LIMIT_CAP:-10000}" \
      "$@"
    ;;
  pipeline-eval-dry-run)
    require_recall_dir
    uv run python "$SEARCH_EVALS/run_pipeline_eval.py" \
      --recall-dir "$DEFAULT_RECALL_DIR" \
      --env-file "${ENV_FILE:-.env}" \
      --limit-cap "${LIMIT_CAP:-10000}" \
      --dry-run \
      "$@"
    ;;
  pipeline-eval-list)
    require_recall_dir
    uv run python "$SEARCH_EVALS/run_pipeline_eval.py" \
      --recall-dir "$DEFAULT_RECALL_DIR" \
      --list \
      "$@"
    ;;
  component|mock-prepare)
    py="${PYTHON:-}"
    if [[ -z "$py" ]]; then
      if [[ -x "$ROOT/.venv/bin/python" ]]; then
        py="$ROOT/.venv/bin/python"
      else
        py="python"
      fi
    fi
    "$py" -m unittest tests.test_search_network_mock_openai -v "$@"
    ;;
  extractor-eval)
    require_query_dataset_dir
    uv run --env-file "${ENV_FILE:-.env}" python "$SEARCH_EVALS/extractor_eval.py" \
      --dataset-dir "$DEFAULT_QUERY_DATASET_DIR" \
      --env-file "${ENV_FILE:-.env}" \
      "$@"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    echo "error: unknown command: $command" >&2
    usage >&2
    exit 2
    ;;
esac
