#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

UV_BIN="${UV_BIN:-uv}"
if ! command -v "$UV_BIN" >/dev/null 2>&1; then
  if [[ -x "$HOME/.local/bin/uv" ]]; then
    UV_BIN="$HOME/.local/bin/uv"
  else
    echo "uv is required; run bin/setup-python first" >&2
    exit 127
  fi
fi

# Focused offline baseline gate. Source-specific integration suites use local
# fixtures and fake providers; they do not read user data or make network calls.
exec "$UV_BIN" run --project . python -m unittest \
  tests.test_core_layout \
  tests.test_ingestion_messages_contract \
  tests.test_import_whatsapp_wacli \
  tests.test_interaction_counts \
  tests.test_build_research_review_csv_linkedin \
  tests.test_discover_contacts_pipeline \
  tests.test_messages_pack \
  tests.test_enrich_primitives \
  tests.test_mcp_install \
  tests.test_pull_runtime_keys \
  -v
