#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

UV_BIN="${UV_BIN:-uv}"
if ! command -v "$UV_BIN" >/dev/null 2>&1; then
  if [[ -x "$HOME/.local/bin/uv" ]]; then
    UV_BIN="$HOME/.local/bin/uv"
  else
    echo "uv is required; run bin/setup-python first" >&2
    exit 127
  fi
fi

# Focused offline baseline gate. This intentionally avoids full unittest
# discovery because some legacy tests require local user data or still assert
# stale skill names. Add tests here once they are deterministic in clean CI.
exec "$UV_BIN" run --project . python -m unittest \
  tests.test_core_layout.CoreLayoutTests.test_json_contracts_and_schemas_parse \
  tests.test_core_layout.CoreLayoutTests.test_pack_skills_have_codex_frontmatter \
  tests.test_core_layout.CoreLayoutTests.test_powerset_login_skill_uses_api_runtime_key_primitives \
  tests.test_core_layout.CoreLayoutTests.test_powerset_setup_skill_combines_login_env_and_mcp \
  tests.test_enrich_primitives.PowersetAuthTests.test_login_requires_explicit_auth0_config \
  tests.test_enrich_primitives.PowersetAuthTests.test_whoami_and_logout_do_not_require_auth0_config \
  tests.test_enrich_primitives.SyncCandidatesTests.test_sync_paginates_and_writes_csv \
  tests.test_enrich_primitives.SyncCandidatesTests.test_sync_falls_back_to_cache_when_unauth \
  tests.test_enrich_primitives.SyncCandidatesTests.test_sync_candidates_requires_explicit_api_config_before_auth \
  tests.test_enrich_primitives.SyncCandidatesTests.test_sync_candidates_use_cached_does_not_need_api_or_credentials \
  tests.test_mcp_install \
  tests.test_pull_runtime_keys \
  tests.test_sync_contact_datalake \
  tests.test_messages_pack.MessagesPackTests.test_upload_research_review_requires_explicit_api_url \
  tests.test_messages_pack.MessagesPackTests.test_upload_research_review_posts_multipart_csv \
  -v
