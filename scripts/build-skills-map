#!/usr/bin/env python3
"""Build a static skills/primitives map page for Powerpacks.

Scans packs/*/skills/*/SKILL.md and packs/*/primitives/*, infers primitive/MCP
references from each skill body, and writes docs/skills-map.html plus
.powerpacks/skills-map/skills-map.json.

Stdlib only. The HTML is self-contained so it can be opened directly in a
browser:

    open docs/skills-map.html
"""

from __future__ import annotations

import html
import json
import re
from datetime import datetime, timezone
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[1]
DOCS_OUT = ROOT / "docs" / "skills-map.html"
JSON_OUT = ROOT / ".powerpacks" / "skills-map" / "skills-map.json"


def now_iso() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def rel(path: Path) -> str:
    return str(path.relative_to(ROOT))


def parse_frontmatter(text: str) -> tuple[dict[str, str], str]:
    if not text.startswith("---\n"):
        return {}, text
    end = text.find("\n---\n", 4)
    if end == -1:
        return {}, text
    raw = text[4:end]
    body = text[end + 5 :]
    data: dict[str, str] = {}
    for line in raw.splitlines():
        if ":" not in line:
            continue
        key, value = line.split(":", 1)
        data[key.strip()] = value.strip().strip('"').strip("'")
    return data, body


def first_heading(body: str) -> str | None:
    for line in body.splitlines():
        if line.startswith("# "):
            return line[2:].strip()
    return None


def collect_primitives() -> dict[str, dict[str, Any]]:
    primitives: dict[str, dict[str, Any]] = {}
    for pack_dir in sorted((ROOT / "packs").glob("*")):
        prim_root = pack_dir / "primitives"
        if not prim_root.exists():
            continue
        for d in sorted(p for p in prim_root.iterdir() if p.is_dir()):
            py = d / f"{d.name}.py"
            files = sorted(p for p in d.iterdir() if p.is_file())
            primitives[d.name] = {
                "name": d.name,
                "pack": pack_dir.name,
                "path": rel(d),
                "entrypoint": rel(py) if py.exists() else None,
                "has_readme": (d / "README.md").exists(),
                "file_count": len(files),
            }
    return primitives


KNOWN_MCP_TOOLS = {
    "autocomplete",
    "count",
    "create_set",
    "create_set_invite",
    "delete_set",
    "enrich_extended_profiles",
    "expand_query",
    "find_mutuals",
    "full_search",
    "get_artifact",
    "hydrate_people",
    "list_company_people",
    "list_contacts",
    "list_conversations",
    "list_set_contacts",
    "list_sets",
    "query_extended_leads",
    "query_results",
    "rerank_candidates",
    "resolve_companies",
    "sales_nav_resolve",
    "sales_nav_resolve_member_ids",
    "sales_nav_search",
    "score_extended_leads",
    "search",
    "search_company_signals",
    "search_roles",
    "search_summaries",
}


def _negative_mention(lower: str, name: str) -> bool:
    """Avoid counting explicit 'do not call/use X' guidance as a dependency."""
    cleaned = lower.replace("*", "").replace("`", "")
    escaped = re.escape(name.lower())
    for para in re.split(r"\n\s*\n", cleaned):
        if re.search(rf"\b(do\s+not|don't|never|does\s+not)\s+(?:call|use|invoke|run)\b[\s\S]{{0,260}}\b{escaped}\b", para):
            return True
    return False


def infer_references(body: str, primitives: dict[str, dict[str, Any]]) -> tuple[list[str], list[str]]:
    refs: list[str] = []
    lower = body.lower()
    code_tokens = {m.group(1).lower() for m in re.finditer(r"`([a-z][a-z0-9_-]{2,})`", body)}
    for name in primitives:
        lname = name.lower()
        hyphen = lname.replace("_", "-")
        strong_patterns = [
            f"primitives/{lname}",
            f"/{lname}.py",
            f" {lname}.py",
            f"/{lname}/",
        ]
        mentioned = any(p in lower for p in strong_patterns) or lname in code_tokens or hyphen in code_tokens
        # For descriptive primitive names, plain-text mentions in workflows are
        # usually meaningful; for short generic names like `auth` or `lib`, they
        # are too noisy and require code/path evidence above.
        if not mentioned and "_" in lname and lname in lower:
            mentioned = True
        if mentioned and not _negative_mention(lower, lname) and not _negative_mention(lower, hyphen):
            refs.append(name)

    function_tokens = {m.group(1).lower() for m in re.finditer(r"\b([a-z][a-z0-9_]{2,})\s*\(", body)}
    tool_labels = {m.group(1).lower() for m in re.finditer(r"\bTool:\s*([a-z][a-z0-9_]{2,})", body, flags=re.IGNORECASE)}
    mcp = sorted(
        t for t in KNOWN_MCP_TOOLS
        if t in tool_labels or (t not in {"search", "count"} and (t in function_tokens or t in code_tokens))
    )
    # If a tool is explicitly negative guidance, leave it out of the dependency
    # list; the skill detail still links the SKILL.md for full nuance.
    mcp = [t for t in mcp if t not in refs and not _negative_mention(lower, t)]
    return sorted(set(refs)), mcp


def collect_skills(primitives: dict[str, dict[str, Any]]) -> list[dict[str, Any]]:
    skills: list[dict[str, Any]] = []
    for path in sorted((ROOT / "packs").glob("*/skills/*/SKILL.md")):
        pack = path.parts[path.parts.index("packs") + 1]
        skill_dir = path.parent.name
        text = path.read_text(errors="replace")
        fm, body = parse_frontmatter(text)
        prim_refs, mcp_refs = infer_references(body, primitives)
        skills.append(
            {
                "name": fm.get("name") or skill_dir,
                "display_name": f"powerset:{fm.get('name') or skill_dir}",
                "pack": pack,
                "path": rel(path),
                "description": fm.get("description") or "",
                "heading": first_heading(body) or (fm.get("name") or skill_dir),
                "markdown": text,
                "primitive_refs": prim_refs,
                "mcp_refs": mcp_refs,
                "primitive_count": len(prim_refs),
                "mcp_count": len(mcp_refs),
            }
        )
    return skills


def build_data() -> dict[str, Any]:
    primitives = collect_primitives()
    skills = collect_skills(primitives)
    packs: dict[str, dict[str, int]] = {}
    for p in primitives.values():
        packs.setdefault(p["pack"], {"skills": 0, "primitives": 0})["primitives"] += 1
    for s in skills:
        packs.setdefault(s["pack"], {"skills": 0, "primitives": 0})["skills"] += 1
    return {
        "generated_at": now_iso(),
        "skills": skills,
        "primitives": sorted(primitives.values(), key=lambda p: (p["pack"], p["name"])),
        "primitive_by_name": primitives,
        "packs": packs,
    }


def html_page(data: dict[str, Any]) -> str:
    payload = json.dumps(data, sort_keys=True)
    escaped_payload = payload.replace("</", "<\\/")
    return f"""<!doctype html>
<html lang=\"en\">
<head>
  <meta charset=\"utf-8\" />
  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />
  <title>Powerpacks Skills Map</title>
  <style>
    :root {{
      color-scheme: dark;
      --bg: #070a12;
      --panel: rgba(255,255,255,.075);
      --panel-2: rgba(255,255,255,.11);
      --border: rgba(255,255,255,.15);
      --text: #eef4ff;
      --muted: #94a3b8;
      --accent: #74f0c7;
      --accent-2: #8ab4ff;
      --warn: #ffd166;
      --shadow: 0 18px 70px rgba(0,0,0,.38);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;
    }}
    * {{ box-sizing: border-box; }}
    body {{ margin: 0; background: radial-gradient(circle at 20% 0%, rgba(116,240,199,.18), transparent 32rem), radial-gradient(circle at 90% 10%, rgba(138,180,255,.22), transparent 34rem), var(--bg); color: var(--text); }}
    header {{ padding: 42px clamp(18px, 4vw, 56px) 20px; }}
    h1 {{ margin: 0; font-size: clamp(34px, 5vw, 64px); letter-spacing: -0.055em; line-height: .95; }}
    .sub {{ margin: 14px 0 0; color: var(--muted); max-width: 820px; font-size: 16px; line-height: 1.55; }}
    .toolbar {{ display: grid; grid-template-columns: minmax(180px, 1fr) 180px 180px; gap: 12px; padding: 18px clamp(18px, 4vw, 56px) 10px; position: sticky; top: 0; z-index: 5; backdrop-filter: blur(18px); background: linear-gradient(to bottom, rgba(7,10,18,.88), rgba(7,10,18,.62)); border-bottom: 1px solid rgba(255,255,255,.08); }}
    input, select {{ width: 100%; border: 1px solid var(--border); border-radius: 14px; background: rgba(255,255,255,.08); color: var(--text); padding: 12px 14px; outline: none; }}
    input:focus, select:focus {{ border-color: var(--accent); box-shadow: 0 0 0 3px rgba(116,240,199,.18); }}
    main {{ display: grid; grid-template-columns: minmax(0, 1fr) minmax(420px, 38vw); gap: 20px; padding: 16px clamp(18px, 4vw, 56px) 56px; }}
    .stats {{ display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 18px; }}
    .stat {{ border: 1px solid var(--border); border-radius: 999px; padding: 8px 12px; color: var(--muted); background: rgba(255,255,255,.06); }}
    .stat strong {{ color: var(--text); }}
    .section {{ margin: 0 0 28px; }}
    .section h2 {{ margin: 0 0 12px; font-size: 14px; color: var(--muted); text-transform: uppercase; letter-spacing: .14em; }}
    .grid {{ display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 14px; }}
    .card {{ border: 1px solid var(--border); background: linear-gradient(180deg, var(--panel-2), var(--panel)); border-radius: 22px; padding: 18px; box-shadow: var(--shadow); cursor: pointer; min-height: 188px; transition: transform .15s ease, border-color .15s ease, background .15s ease; }}
    .card:hover, .card.active {{ transform: translateY(-2px); border-color: rgba(116,240,199,.72); background: rgba(116,240,199,.10); }}
    .kicker {{ display:flex; align-items:center; gap:8px; color: var(--accent); font-size: 12px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; }}
    .title {{ margin: 12px 0 8px; font-size: 22px; font-weight: 800; letter-spacing: -.025em; }}
    .desc {{ color: var(--muted); font-size: 13px; line-height: 1.45; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }}
    .chips {{ display: flex; flex-wrap: wrap; gap: 7px; margin-top: 14px; }}
    .chip {{ border: 1px solid rgba(255,255,255,.13); border-radius: 999px; padding: 5px 8px; color: #cbd5e1; font-size: 12px; background: rgba(0,0,0,.16); }}
    aside {{ position: sticky; top: 86px; align-self: start; border: 1px solid var(--border); border-radius: 26px; background: rgba(8,13,24,.82); box-shadow: var(--shadow); backdrop-filter: blur(20px); overflow: hidden; }}
    .detail {{ padding: 22px; }}
    .detail h3 {{ margin: 0 0 8px; font-size: 28px; letter-spacing: -.04em; }}
    .detail p {{ color: var(--muted); line-height: 1.5; }}
    .label {{ margin-top: 20px; margin-bottom: 8px; color: var(--muted); font-size: 12px; text-transform: uppercase; letter-spacing: .14em; }}
    .list {{ display:grid; gap:8px; }}
    .row {{ border: 1px solid rgba(255,255,255,.11); border-radius: 14px; padding: 10px 12px; background: rgba(255,255,255,.06); }}
    .row strong {{ display:block; color: var(--text); }}
    .row small {{ color: var(--muted); word-break: break-all; }}
    .markdown {{ max-height: 520px; overflow: auto; white-space: pre-wrap; word-break: break-word; border: 1px solid rgba(255,255,255,.11); border-radius: 16px; padding: 14px; background: rgba(0,0,0,.26); color: #dbeafe; font: 12px/1.48 ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; }}
    .empty {{ color: var(--muted); border: 1px dashed var(--border); border-radius: 18px; padding: 18px; }}
    a {{ color: var(--accent-2); text-decoration: none; }}
    code {{ color: var(--accent); }}
    @media (max-width: 980px) {{ main {{ grid-template-columns: 1fr; }} aside {{ position: static; }} .toolbar {{ grid-template-columns: 1fr; }} }}
  </style>
</head>
<body>
  <header>
    <div class=\"kicker\">Powerset Powerpacks</div>
    <h1>Skills Map</h1>
    <p class=\"sub\">Browse skill cards by pack, click a skill to see the primitives and MCP tools it references. Display names are shown with a proposed <code>powerset:</code> prefix for easier mental namespacing.</p>
  </header>
  <div class=\"toolbar\">
    <input id=\"q\" aria-label=\"Search skills\" placeholder=\"Search skills, primitives, MCP tools…\" />
    <select id=\"pack\" aria-label=\"Filter by pack\"></select>
    <select id=\"sort\" aria-label=\"Sort skills\">
      <option value=\"pack\">Pack order</option>
      <option value=\"name\">Name</option>
      <option value=\"prims\">Most primitives</option>
    </select>
  </div>
  <main>
    <section>
      <div class=\"stats\" id=\"stats\"></div>
      <div id=\"sections\"></div>
    </section>
    <aside aria-live=\"polite\"><div class=\"detail\" id=\"detail\"></div></aside>
  </main>
  <script id=\"data\" type=\"application/json\">{escaped_payload}</script>
  <script>
    const data = JSON.parse(document.getElementById('data').textContent);
    const q = document.getElementById('q');
    const pack = document.getElementById('pack');
    const sort = document.getElementById('sort');
    const sections = document.getElementById('sections');
    const stats = document.getElementById('stats');
    const detail = document.getElementById('detail');
    let selected = data.skills[0]?.name;

    function esc(s) {{ return String(s ?? '').replace(/[&<>\"]/g, c => ({{'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;'}}[c])); }}
    function normalize(s) {{ return String(s ?? '').toLowerCase(); }}
    function skillHaystack(s) {{ return normalize([s.name, s.display_name, s.pack, s.description, ...s.primitive_refs, ...s.mcp_refs].join(' ')); }}

    function initFilters() {{
      const packs = [...new Set(data.skills.map(s => s.pack))].sort();
      pack.innerHTML = '<option value="all">All packs</option>' + packs.map(p => `<option value="${{esc(p)}}">${{esc(p)}}</option>`).join('');
    }}

    function filteredSkills() {{
      const query = normalize(q.value.trim());
      let list = data.skills.filter(s => (pack.value === 'all' || s.pack === pack.value) && (!query || skillHaystack(s).includes(query)));
      if (sort.value === 'name') list.sort((a,b) => a.name.localeCompare(b.name));
      else if (sort.value === 'prims') list.sort((a,b) => (b.primitive_count + b.mcp_count) - (a.primitive_count + a.mcp_count));
      else list.sort((a,b) => a.pack.localeCompare(b.pack) || a.name.localeCompare(b.name));
      return list;
    }}

    function renderStats(list) {{
      const prims = new Set(list.flatMap(s => s.primitive_refs));
      const mcp = new Set(list.flatMap(s => s.mcp_refs));
      stats.innerHTML = `
        <div class="stat"><strong>${{list.length}}</strong> skills</div>
        <div class="stat"><strong>${{Object.keys(data.packs).length}}</strong> packs</div>
        <div class="stat"><strong>${{data.primitives.length}}</strong> primitives total</div>
        <div class="stat"><strong>${{prims.size}}</strong> primitives referenced</div>
        <div class="stat"><strong>${{mcp.size}}</strong> MCP/tool refs</div>
        <div class="stat">generated <strong>${{esc(data.generated_at)}}</strong></div>`;
    }}

    function card(s) {{
      const chips = [...s.primitive_refs.slice(0, 3).map(p => `<span class="chip">${{esc(p)}}</span>`), ...s.mcp_refs.slice(0, 2).map(t => `<span class="chip">mcp:${{esc(t)}}</span>`)].join('');
      return `<article class="card ${{s.name === selected ? 'active' : ''}}" tabindex="0" role="button" data-skill="${{esc(s.name)}}">
        <div class="kicker">${{esc(s.pack)}} · ${{s.primitive_count}} prim · ${{s.mcp_count}} tool</div>
        <div class="title">${{esc(s.display_name)}}</div>
        <div class="desc">${{esc(s.description || s.heading)}}</div>
        <div class="chips">${{chips || '<span class="chip">no refs inferred</span>'}}</div>
      </article>`;
    }}

    function renderSections() {{
      const list = filteredSkills();
      renderStats(list);
      if (!list.length) {{ sections.innerHTML = '<div class="empty">No skills match the current filters.</div>'; renderDetail(null); return; }}
      const grouped = new Map();
      for (const s of list) {{ if (!grouped.has(s.pack)) grouped.set(s.pack, []); grouped.get(s.pack).push(s); }}
      sections.innerHTML = [...grouped.entries()].map(([p, skills]) => `<div class="section"><h2>${{esc(p)}} - ${{skills.length}} skills</h2><div class="grid">${{skills.map(card).join('')}}</div></div>`).join('');
      if (!list.some(s => s.name === selected)) selected = list[0].name;
      renderDetail(data.skills.find(s => s.name === selected));
    }}

    function renderDetail(s) {{
      if (!s) {{ detail.innerHTML = '<div class="empty">Select a skill card.</div>'; return; }}
      const primitiveRows = s.primitive_refs.map(name => {{
        const p = data.primitive_by_name[name] || {{name}};
        return `<div class="row"><strong>${{esc(name)}}</strong><small>${{esc(p.path || '')}}${{p.entrypoint ? '<br>' + esc(p.entrypoint) : ''}}</small></div>`;
      }}).join('') || '<div class="empty">No primitive references inferred from SKILL.md.</div>';
      const mcpRows = s.mcp_refs.map(name => `<div class="row"><strong>mcp:${{esc(name)}}</strong><small>Referenced by skill body</small></div>`).join('') || '<div class="empty">No MCP/tool references inferred.</div>';
      detail.innerHTML = `
        <div class="kicker">${{esc(s.pack)}} pack</div>
        <h3>${{esc(s.display_name)}}</h3>
        <p>${{esc(s.description)}}</p>
        <div class="label">Skill file</div>
        <div class="row"><strong>${{esc(s.name)}}</strong><small>${{esc(s.path)}}</small></div>
        <pre class="markdown">${{esc(s.markdown || '')}}</pre>
        <div class="label">Primitives used</div>
        <div class="list">${{primitiveRows}}</div>
        <div class="label">MCP / tool refs</div>
        <div class="list">${{mcpRows}}</div>`;
    }}

    sections.addEventListener('click', e => {{
      const card = e.target.closest('.card');
      if (!card) return;
      selected = card.dataset.skill;
      renderSections();
    }});
    sections.addEventListener('keydown', e => {{
      if (e.key !== 'Enter' && e.key !== ' ') return;
      const card = e.target.closest('.card');
      if (!card) return;
      e.preventDefault();
      selected = card.dataset.skill;
      renderSections();
    }});
    [q, pack, sort].forEach(el => el.addEventListener('input', renderSections));
    initFilters();
    renderSections();
  </script>
</body>
</html>
"""


def main() -> int:
    data = build_data()
    JSON_OUT.parent.mkdir(parents=True, exist_ok=True)
    DOCS_OUT.parent.mkdir(parents=True, exist_ok=True)
    JSON_OUT.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")
    DOCS_OUT.write_text(html_page(data))
    print(f"skills-map: wrote {rel(DOCS_OUT)} ({len(data['skills'])} skills, {len(data['primitives'])} primitives)")
    print(f"skills-map: wrote {rel(JSON_OUT)}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
