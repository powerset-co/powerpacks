{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://powerpacks/schemas/decomposed-query.schema.json",
  "title": "DecomposedQuery",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "intent_type",
    "source_type",
    "normalized_query",
    "vertical"
  ],
  "properties": {
    "intent_type": {
      "type": "string",
      "enum": ["role_search"]
    },
    "source_type": {
      "type": "string",
      "enum": ["query", "job_description", "url"]
    },
    "normalized_query": {
      "type": "string"
    },
    "vertical": {
      "type": "string",
      "enum": ["people_by_role"]
    },
    "role_search_filters": {
      "$ref": "./role-search-filters.schema.json"
    },
    "company_names": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
