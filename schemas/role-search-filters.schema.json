{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://powerpacks/schemas/role-search-filters.schema.json",
  "title": "RoleSearchFilters",
  "type": "object",
  "additionalProperties": false,
  "required": ["semantic_query"],
  "properties": {
    "semantic_query": { "type": "string" },
    "bm25_queries": {
      "type": "array",
      "items": { "type": "string" }
    },
    "company_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "company_names": {
      "type": "array",
      "items": { "type": "string" }
    },
    "company_cities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "company_states": {
      "type": "array",
      "items": { "type": "string" }
    },
    "company_countries": {
      "type": "array",
      "items": { "type": "string" }
    },
    "company_metro_areas": {
      "type": "array",
      "items": { "type": "string" }
    },
    "company_macro_regions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "entity_types": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sector_types": {
      "type": "array",
      "items": { "type": "string" }
    },
    "technology_types": {
      "type": "array",
      "items": { "type": "string" }
    },
    "customer_types": {
      "type": "array",
      "items": { "type": "string" }
    },
    "investors": {
      "type": "array",
      "items": { "type": "string" }
    },
    "yc_batches": {
      "type": "array",
      "items": { "type": "string" }
    },
    "funding_stage_min": { "type": "string" },
    "funding_stage_max": { "type": "string" },
    "funding_amount_min": { "type": "number" },
    "funding_amount_max": { "type": "number" },
    "headcount_min": { "type": "integer" },
    "headcount_max": { "type": "integer" },
    "last_funding_before": { "type": "string" },
    "last_funding_after": { "type": "string" },
    "valuation_min": { "type": "number" },
    "valuation_max": { "type": "number" },
    "founded_year_min": { "type": "integer" },
    "founded_year_max": { "type": "integer" },
    "education_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "role_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "cities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "states": {
      "type": "array",
      "items": { "type": "string" }
    },
    "countries": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metro_areas": {
      "type": "array",
      "items": { "type": "string" }
    },
    "macro_regions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "seniority_bands": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "entry",
          "junior",
          "mid",
          "senior",
          "staff",
          "principal",
          "manager",
          "director",
          "vice_president",
          "c_suite"
        ]
      }
    },
    "role_tracks": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "engineering",
          "data",
          "product",
          "design",
          "sales",
          "marketing",
          "operations",
          "business_dev",
          "finance",
          "strategy"
        ]
      }
    },
    "degree_levels": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["bachelors", "masters", "phd", "mba"]
      }
    },
    "is_current": { "type": "boolean" },
    "years_experience_min": { "type": "number" },
    "years_experience_max": { "type": "number" },
    "age_min": { "type": "integer" },
    "age_max": { "type": "integer" },
    "position_after_date": { "type": "string" },
    "position_before_date": { "type": "string" }
  }
}
